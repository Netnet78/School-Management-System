<UserControl x:Class="SchoolManagement.Presentation.Shared.Components.CustomContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolManagement.Presentation.Shared.Components"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters"
             xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="MainContentControl">

    <UserControl.Resources>
        <conv:BooleanInverseConverter x:Key="BooleanToVisibilityConverterReversed" />

        <Storyboard x:Key="ContentFadeIn">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.150" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="ContentFadeOut">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.200" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <mah:TransitioningContentControl x:Name="ContentContainer"
                                       VirtualizingPanel.VirtualizationMode="Recycling"
                                       VirtualizingPanel.IsContainerVirtualizable="True"
                                       VirtualizingPanel.IsVirtualizing="True"
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Stretch" 
                                       VerticalAlignment="Stretch" 
                                       UseLayoutRounding="True"
                                       Opacity="1"
                                       Visibility="Visible"
                                       Transition="Normal"
                                       Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                       Content="{Binding CurrentView, RelativeSource={RelativeSource AncestorType=UserControl}}">
        </mah:TransitioningContentControl>
    </Grid>
</UserControl>
