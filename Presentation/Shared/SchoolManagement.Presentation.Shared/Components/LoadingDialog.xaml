<UserControl x:Class="SchoolManagement.Presentation.Shared.Components.LoadingDialog"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:local="clr-namespace:SchoolManagement.Presentation.Shared.Components"
                xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters"
                xmlns:materialDesigns="http://materialdesigninxaml.net/winfx/xaml/themes" 
                xmlns:services="clr-namespace:SchoolManagement.Presentation.Shared.Services" 
                d:DataContext="{d:DesignInstance Type=services:LoadingService}"
                mc:Ignorable="d" 
                d:DesignHeight="550" d:DesignWidth="800"
                Background="Transparent">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True"/>
    </UserControl.Resources>

    <Border x:Name="ProcessingMessage"
        Opacity="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Padding="20 10 20 20"
        CornerRadius="10"
        Background="White"
        BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
        BorderThickness="4"
        MaxWidth="410"
        Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border.Effect>
            <DropShadowEffect RenderingBias="Quality" BlurRadius="10" ShadowDepth="10" Opacity="0.25"/>
        </Border.Effect>

        <StackPanel Orientation="Vertical">
            <Grid x:Name="LoadingIndicator" Visibility="Visible">
                <materialDesigns:PackIcon
                    x:Name="LoadingIcon"
                    Kind="Loading"
                    Foreground="#FF0030FF"
                    Width="128"
                    Height="128"
                    HorizontalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                    <materialDesigns:PackIcon.RenderTransform>
                        <RotateTransform Angle="0" />
                    </materialDesigns:PackIcon.RenderTransform>
                    <materialDesigns:PackIcon.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="LoadingIcon"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                        To="360" Duration="0:0:2"/>
                                    <DoubleAnimation
                                        Storyboard.TargetName="LoadingImage"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                        To="-360" Duration="0:0:2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </materialDesigns:PackIcon.Triggers>
                </materialDesigns:PackIcon>
                <Image Source="pack://application:,,,/SchoolManagement.Assets;component/Images/dbslogo_filled.png" 
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant"
                        x:Name="LoadingImage" 
                        RenderTransformOrigin="0.5,0.5"
                        VerticalAlignment="Center">
                    <Image.RenderTransform>
                        <RotateTransform/>
                    </Image.RenderTransform>
                </Image>
            </Grid>

            <StackPanel Margin="0 10 0 0">
                <TextBlock
                    x:Name="LoadingTextBlock"
                    TextWrapping="Wrap"
                    MinWidth="360"
                    TextAlignment="Center"
                    Text="{Binding LoadingText, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='កំពុងដំណើរការទិន្នន័យ! សូមមេត្តារងចាំ...'}"
                    FontSize="24"
                    Margin="0 5 0 0"
                    Foreground="#FF0030FF" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
