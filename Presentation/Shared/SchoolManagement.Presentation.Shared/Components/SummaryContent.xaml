<UserControl x:Class="SchoolManagement.Presentation.Shared.Components.SummaryContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolManagement.Presentation.Shared.Components"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="800">
    <Border Grid.Row="5" Margin="0 10 0 0" Padding="8"
                Background="{DynamicResource MaterialDesign.Brush.Primary}">
        <TextBlock x:Name="SummaryText"
                       Text="{Binding Summary, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                       FontSize="14" FontWeight="Normal"/>
    </Border>
</UserControl>
