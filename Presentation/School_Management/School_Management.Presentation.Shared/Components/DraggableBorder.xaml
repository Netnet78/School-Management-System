<UserControl x:Class="School_Management.Presentation.Shared.Components.DraggableBorder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:School_Management.Presentation.Shared.Components"
             xmlns:primitives="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
             xmlns:materialDesigns="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- Corner Thumbs -->
        <primitives:Thumb DragDelta="BottomRightThumb_DragDelta"
                          Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                          Cursor="SizeNWSE" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
        <primitives:Thumb DragDelta="BottomLeftThumb_DragDelta"
                          Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                          Cursor="SizeNESW" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
        <primitives:Thumb DragDelta="TopRightThumb_DragDelta"
                          Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top"
                          Cursor="SizeNESW" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
        <primitives:Thumb DragDelta="TopLeftThumb_DragDelta"
                          Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                          Cursor="SizeNWSE" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>

        <!-- Side Thumbs -->
        <primitives:Thumb DragDelta="LeftThumb_DragDelta"
                          Width="10" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                          Cursor="SizeWE" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
        <primitives:Thumb DragDelta="RightThumb_DragDelta"
                          Width="10" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                          Cursor="SizeWE" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
        <primitives:Thumb DragDelta="TopThumb_DragDelta"
                          Height="10" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Cursor="SizeNS" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
        <primitives:Thumb DragDelta="BottomThumb_DragDelta"
                          Height="10" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                          Cursor="SizeNS" Background="Transparent" BorderThickness="0" Foreground="Transparent"/>
    </Grid>
</UserControl>
