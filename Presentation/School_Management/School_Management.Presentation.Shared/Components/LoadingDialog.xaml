<UserControl x:Class="School_Management.Presentation.Shared.Components.LoadingDialog"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:local="clr-namespace:School_Management.Presentation.Shared.Components"
                xmlns:conv="clr-namespace:School_Management.Presentation.Shared.XAMLConverters"
                xmlns:materialDesigns="http://materialdesigninxaml.net/winfx/xaml/themes" 
                xmlns:services="clr-namespace:School_Management.Presentation.Shared.Services" 
                d:DataContext="{d:DesignInstance Type=services:LoadingService}"
                mc:Ignorable="d" 
                d:DesignHeight="550" d:DesignWidth="800"
                Background="Transparent">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True"/>

        <Storyboard x:Key="ProgressCogRotateAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftCog" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="-426.8"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightCog" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="426.8"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterCog" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DimLeftCog" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="-426.8"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DimRightCog" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="426.8"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DimCenterCog" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="ProcessingMessage"
        Opacity="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Padding="20 10 20 20"
        CornerRadius="10"
        Background="White"
        BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
        BorderThickness="4"
        MaxWidth="410"
        Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border.Effect>
            <DropShadowEffect RenderingBias="Quality" BlurRadius="10" ShadowDepth="10" Opacity="0.25"/>
        </Border.Effect>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LoadingStates">

                <!-- LOADING -->
                <VisualState x:Name="Loading">
                    <Storyboard>

                        <!-- OPACITY (FADE IN) -->
                        <DoubleAnimation Storyboard.TargetName="LoadingIndicator"
                         Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.3"/>

                        <!-- SPIN -->
                        <DoubleAnimation Storyboard.TargetName="LoadingIcon"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         To="360" Duration="0:0:2" RepeatBehavior="Forever"/>

                        <DoubleAnimation Storyboard.TargetName="LoadingImage"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         To="-360" Duration="0:0:2" RepeatBehavior="Forever"/>

                    </Storyboard>
                </VisualState>
                
                <!-- PROGRESS -->
                <VisualState x:Name="Progress">
                    <Storyboard>

                        <!-- OPACITY -->
                        <DoubleAnimation Storyboard.TargetName="ProgressIndicator"
                         Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.5"/>

                        <DoubleAnimation Storyboard.TargetName="ProgressTextBlock"
                         Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.5"/>

                    </Storyboard>
                </VisualState>
                
                <!-- COMPLETED -->
                <VisualState x:Name="Success">
                    <Storyboard>
                        <!-- OPACITY -->
                        <DoubleAnimation Storyboard.TargetName="ButtonSection"
                         Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.4"/>

                    </Storyboard>
                </VisualState>
                
                <!-- ERROR -->
                <VisualState x:Name="Error">
                    <Storyboard>

                        <!-- OPACITY -->
                        <DoubleAnimation Storyboard.TargetName="ErrorIndicator"
                         Storyboard.TargetProperty="Opacity"
                         To="1" Duration="0:0:0.3"/>

                    </Storyboard>
                </VisualState>
                
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <StackPanel Orientation="Vertical">
            <Grid x:Name="LoadingIndicator" Visibility="Visible">
                <materialDesigns:PackIcon
                    x:Name="LoadingIcon"
                    Kind="Loading"
                    Foreground="#FF0030FF"
                    Width="128"
                    Height="128"
                    HorizontalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                    <materialDesigns:PackIcon.RenderTransform>
                        <RotateTransform Angle="0" />
                    </materialDesigns:PackIcon.RenderTransform>
                </materialDesigns:PackIcon>
                <Image Source="/Sources/Images/dbslogo_filled.png" 
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant"
                        x:Name="LoadingImage" 
                        RenderTransformOrigin="0.5,0.5"
                        VerticalAlignment="Center">
                    <Image.RenderTransform>
                        <RotateTransform/>
                    </Image.RenderTransform>
                </Image>
            </Grid>

            <Grid x:Name="ProgressIndicator" Margin="0 0 0 10" Visibility="Collapsed" Opacity="0">
                <materialDesigns:PackIcon Kind="Loading" Width="128" Height="128" Visibility="Hidden" />

                <Grid x:Name="DimLayer" Opacity="0.3">
                    <Image x:Name="DimCenterCog" Source="/Sources/Images/dbslogo_filled.png" 
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant" 
                        RenderTransformOrigin="0.5,0.5"
                        VerticalAlignment="Center">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="DimRightCog"
                        Source="/Sources/Images/dbslogo_filled.png"
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant" 
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                        <Image.RenderTransform>
                            <TransformGroup>
                                <!-- Scale -->
                                <ScaleTransform ScaleX="1" ScaleY="1"/>

                                <SkewTransform/>

                                <!-- Rotation -->
                                <RotateTransform Angle="66.8"/>

                                <!-- Position -->
                                <TranslateTransform X="85" Y="16.058"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="DimLeftCog"
                        Source="/Sources/Images/dbslogo_filled.png"
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant" 
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                        <Image.RenderTransform>
                            <TransformGroup>
                                <!-- Scale -->
                                <ScaleTransform ScaleX="1" ScaleY="1"/>

                                <SkewTransform/>

                                <!-- Rotation -->
                                <RotateTransform Angle="-66.8"/>

                                <!-- Position -->
                                <TranslateTransform X="-85" Y="16.058"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Grid>

                <Grid x:Name="RevealLayer">
                    <Grid.OpacityMask>
                        <LinearGradientBrush x:Name="RevealBrush"
                                                                StartPoint="0 0"
                                                                EndPoint="1 0">
                            <GradientStop x:Name="LeftStop" Color="Black" Offset="0"/>
                            <GradientStop x:Name="RightStop" Color="Transparent" Offset="0"/>
                        </LinearGradientBrush>
                    </Grid.OpacityMask>

                    <Image x:Name="CenterCog" Source="/Sources/Images/dbslogo_filled.png" 
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant" 
                        RenderTransformOrigin="0.5,0.5"
                        VerticalAlignment="Center">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="RightCog"
                        Source="/Sources/Images/dbslogo_filled.png"
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant" 
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                        <Image.RenderTransform>
                            <TransformGroup>
                                <!-- Scale -->
                                <ScaleTransform ScaleX="1" ScaleY="1"/>

                                <SkewTransform/>

                                <!-- Rotation -->
                                <RotateTransform Angle="66.8"/>

                                <!-- Position -->
                                <TranslateTransform X="85" Y="16.058"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="LeftCog"
                        Source="/Sources/Images/dbslogo_filled.png"
                        Width="64"
                        RenderOptions.BitmapScalingMode="Fant" 
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                        <Image.RenderTransform>
                            <TransformGroup>
                                <!-- Scale -->
                                <ScaleTransform ScaleX="1" ScaleY="1"/>

                                <SkewTransform/>

                                <!-- Rotation -->
                                <RotateTransform Angle="-66.8"/>

                                <!-- Position -->
                                <TranslateTransform X="-85" Y="16.058"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
            </Grid>

            <Grid x:Name="ErrorIndicator" Visibility="Collapsed">
                <materialDesigns:PackIcon Kind="Error" 
                                            Foreground="Red"
                                            Width="64"
                                            Height="64"
                                            HorizontalAlignment="Center"/>
            </Grid>

            <Grid x:Name="SuccessIndicator" Visibility="Collapsed">
                <materialDesigns:PackIcon Kind="SuccessCircle" 
                                            Foreground="LimeGreen"
                                            Width="64"
                                            Height="64"
                                            HorizontalAlignment="Center"/>
            </Grid>
            
            <StackPanel Margin="0 10 0 0">
                <TextBlock
                    x:Name="ProgressTextBlock"
                    Text="{Binding ProgressValue, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='100%'}"
                    FontSize="24"
                    Foreground="#FF0030FF" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"/>
                <TextBlock
                    x:Name="LoadingTextBlock"
                    TextWrapping="Wrap"
                    MinWidth="360"
                    TextAlignment="Center"
                    Text="{Binding LoadingText, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='កំពុងដំណើរការទិន្នន័យ! សូមមេត្តារងចាំ...'}"
                    FontSize="24"
                    Margin="0 5 0 0"
                    Foreground="#FF0030FF" />
            </StackPanel>

            <StackPanel Margin="0 10 0 0" 
                        Orientation="Vertical" 
                        Opacity="0"
                        Visibility="Collapsed"
                        x:Name="ButtonSection">
                <Button HorizontalAlignment="Stretch" Click="OKButtonClick">
                    <StackPanel Orientation="Horizontal">
                        <materialDesigns:PackIcon Kind="CheckCircle" />
                        <TextBlock Margin="10 0 0 0">OKAY</TextBlock>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
