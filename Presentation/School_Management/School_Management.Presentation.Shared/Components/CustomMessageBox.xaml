<Window x:Class="School_Management.Presentation.Shared.Components.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:School_Management.Presentation.Shared.Components"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        xmlns:materialDesigns="http://materialdesigninxaml.net/winfx/xaml/themes"
        Background="Transparent">
    <Border Padding="20" Background="White" 
            BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
            BorderThickness="2"
            CornerRadius="10"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <StackPanel Width="300" TextElement.FontFamily="{StaticResource NotoSansKhmer}">

            <StackPanel Margin="0 0 0 20" Orientation="Horizontal">
                <Border Name="IconBorder" Margin="0 0 10 0" Padding="6px" CornerRadius="100" Background="{DynamicResource MaterialDesign.Brush.Primary}">
                    <materialDesigns:PackIcon Name="Icon" Foreground="White" Kind="QuestionMark"  VerticalAlignment="Center" Width="24" Height="24"/>
                </Border>
                <TextBlock x:Name="TitleText"
                       Text="Title"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="MessageText"
                       Text="កុំព្យូទ័ររបស់អ្នកត្រូវបានគេ hack"
                       TextWrapping="Wrap"
                       Margin="0 0 0 20"
                       FontSize="16"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="OK"
                        Name="OKButton"
                        Visibility="Collapsed"
                        Width="80"
                        Margin="5"
                        Click="Ok_Click"/>

                <Button Content="Cancel"
                        Name="CancelButton"
                        Visibility="Collapsed"
                        Width="80"
                        Margin="5"
                        Click="Cancel_Click"/>

                <Button Content="Yes"
                        Name="YesButton"
                        Visibility="Collapsed"
                        Width="80"
                        Margin="5"
                        Click="Yes_Click"/>

                <Button Content="No"
                        Name="NoButton"
                        Visibility="Collapsed"
                        Width="80"
                        Margin="5"
                        Click="No_Click"/>

                <Button Content="Retry"
                        Name="RetryButton"
                        Visibility="Collapsed"
                        Width="80"
                        Margin="5"
                        Click="Retry_Click"/>

                <Button Content="Abort"
                        Name="AbortButton"
                        Visibility="Collapsed"
                        Width="80"
                        Margin="5"
                        Click="Abort_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
