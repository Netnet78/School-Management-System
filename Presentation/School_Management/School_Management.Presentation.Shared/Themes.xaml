<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ResourceDictionary.MergedDictionaries>
        <!--<ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml"/>-->
        <!--<ResourceDictionary Source="/Colors.xaml"/>-->
        <!--<materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#FF002573" SecondaryColor="#FF0064FF"/>-->
        <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#FF002573" SecondaryColor="#FF0064FF" />
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <FontFamily x:Key="NotoSansKhmer">
        pack://application:,,,/Sources/Fonts/#Noto Sans Khmer
    </FontFamily>
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
    </Style>

    <Style TargetType="Control">
        <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
    </Style>

</ResourceDictionary>