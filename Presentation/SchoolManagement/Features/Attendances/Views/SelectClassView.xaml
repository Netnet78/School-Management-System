<UserControl x:Class="SchoolManagement.Presentation.Features.Attendances.Views.SelectClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Attendances.ViewModels"
             xmlns:classModels="clr-namespace:SchoolManagement.Core.Features.Classes.Models;assembly=SchoolManagement.Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance Type=viewmodels:SelectClassViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="800">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" Collapse="True" IsReversed="True" />
    </UserControl.Resources>

    <Grid Background="White" TextElement.FontFamily="{StaticResource NotoSansKhmer}" TextElement.FontSize="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" />
            </Button>
            <StackPanel>
                <TextBlock Text="បន្ថែមវត្តមាន" FontSize="24" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="12" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock Text="ជំហានទី 1" FontSize="13" Foreground="White" />
                    </Border>
                    <TextBlock Text="សូមជ្រើសរើសថ្នាក់" FontSize="16" Opacity=".7" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="ថ្នាក់រៀនទាំងអស់" FontSize="18" FontWeight="Bold" Margin="20,0,20,10" />


        <ListBox ItemsSource="{Binding Classes}"
                         BorderThickness="0"
                         Background="Transparent"
                        Grid.Row="2"
            >
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type classModels:Class}">
                    <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="8" Margin="0,0,0,8" Padding="16">
                        <Button Command="{Binding DataContext.SelectClassCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Background="Blue" BorderThickness="0"
                                        HorizontalContentAlignment="Stretch" MinHeight="120"
                                        Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="{Binding KhmerName}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Name}" FontSize="14" Opacity=".6" Margin="0,4,0,0" />
                            </StackPanel>
                        </Button>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel>
            <StackPanel Visibility="{Binding HasClasses, Converter={StaticResource BooleanToVisibilityConverterReversed}}"
                            Margin="0,40,0,0" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="SchoolOutline" Width="48" Height="48" Foreground="#BDBDBD" HorizontalAlignment="Center" />
                <TextBlock Text="មិនទាន់មានថ្នាក់រៀនទេ" FontSize="18" Foreground="#9E9E9E" Margin="0,10,0,0" HorizontalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Height="4" Background="{DynamicResource MaterialDesign.Brush.Secondary}" />
        </Grid>
    </Grid>
</UserControl>
