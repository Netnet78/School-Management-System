<UserControl x:Class="SchoolManagement.Presentation.Features.Attendances.Views.SelectStudentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Attendances.ViewModels"
             xmlns:studentModels="clr-namespace:SchoolManagement.Core.Features.Students.Models;assembly=SchoolManagement.Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance Type=viewmodels:SelectStudentViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="800">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" Collapse="True" IsReversed="True" />
    </UserControl.Resources>

    <Grid Background="White" TextElement.FontFamily="{StaticResource NotoSansKhmer}" TextElement.FontSize="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" />
            </Button>
            <StackPanel>
                <TextBlock Text="បន្ថែមវត្តមាន" FontSize="24" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="12" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock Text="ជំហានទី 2" FontSize="13" Foreground="White" />
                    </Border>
                    <TextBlock Text="{Binding StepTitle}" FontSize="16" Opacity=".7" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="សូមជ្រើសរើសសិស្ស" FontSize="18" FontWeight="Bold" Margin="20,0,20,10" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,0,20,10">
            <ItemsControl ItemsSource="{Binding Students}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type studentModels:StudentClass}">
                        <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="8" Margin="20,0,20,8" Padding="16">
                            <Button Command="{Binding DataContext.SelectStudentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Stretch" MinHeight="48">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}" CornerRadius="20"
                                            Width="40" Height="40" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Student.Id, StringFormat={}{0:0}}" FontSize="16"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Student.FullName}" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Student.LatinFullName}" FontSize="14" Opacity=".6" Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Height="4" Background="{DynamicResource MaterialDesign.Brush.Secondary}" />
        </Grid>
    </Grid>
</UserControl>
