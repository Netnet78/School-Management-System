<UserControl x:Class="SchoolManagement.Presentation.Features.Subjects.Views.AddSubjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Subjects.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:AddSubjectViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="700">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BookPlus" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="បន្ថែមមុខវិជ្ជាថ្មី" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                    Padding="20" CornerRadius="4" Margin="20,0,20,20">
                <StackPanel>
                    <TextBlock Text="ព័ត៌មានមុខវិជ្ជា" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        <!-- Name (English) -->
                        <TextBlock Text="ឈ្មោះ (អង់គ្លេស):" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Column="1" Margin="0,0,0,12"
                                 Text="{Binding Name}"
                                 Padding="6" FontSize="14"
                                 materialDesign:HintAssist.Hint="Enter subject name in English"/>

                        <!-- Name (Khmer) -->
                        <TextBlock Grid.Row="1" Text="ឈ្មោះ (ខ្មែរ):" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                                 Text="{Binding KhmerName}"
                                 Padding="6" FontSize="14"
                                 materialDesign:HintAssist.Hint="បញ្ចូលឈ្មោះមុខវិជ្ជាជាភាសាខ្មែរ"/>

                        <!-- Max Score -->
                        <TextBlock Grid.Row="2" Text="ពិន្ទុអតិបរមា:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,12"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"
                                 Text="{Binding MaxScore}"
                                 Padding="6" FontSize="14" Width="120" HorizontalAlignment="Left"/>

                        <!-- Is Active -->
                        <CheckBox Grid.Row="3" Grid.Column="1"
                                  IsChecked="{Binding IsActive}"
                                  Content="សកម្ម"
                                  FontSize="14" Margin="0,0,0,12"/>
                    </Grid>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Command="{Binding CancelCommand}"
                                Margin="5" FontSize="14" Background="#9E9E9E" Foreground="White">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Margin="0,0,3,0"/>
                                <TextBlock Text="បោះបង់"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveCommand}"
                                Margin="5" FontSize="14" Background="#4CAF50" Foreground="White">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,3,0"/>
                                <TextBlock Text="រក្សាទុក"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Saving indicator -->
                    <Grid Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}" Height="30" Margin="0,10,0,0">
                        <ProgressBar IsIndeterminate="True" Height="20"/>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Grid.Row="1" Background="#44000000"
              Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="កំពុងរក្សាទុក..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
