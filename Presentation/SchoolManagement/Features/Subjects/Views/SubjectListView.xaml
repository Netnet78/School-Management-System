<UserControl x:Class="SchoolManagement.Presentation.Features.Subjects.Views.SubjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Subjects.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:SubjectListViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ====== HEADER ====== -->
        <StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BookOpenVariant" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="គ្រប់គ្រងមុខវិជ្ជា" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="បន្ថែម កែប្រែ និងលុបមុខវិជ្ជា" FontSize="13" Foreground="#666" Margin="36,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- ====== TOOLBAR ====== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,0,20,10" HorizontalAlignment="Right">
            <Button Command="{Binding AddSubjectCommand}"
                    Padding="10,5" Margin="0,0,10,0"
                    Background="#4CAF50" Foreground="White"
                    Visibility="{Binding CanManageSubjects, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="បន្ថែមមុខវិជ្ជា" />
                </StackPanel>
            </Button>
            <Button Command="{Binding RefreshCommand}"
                    Padding="10,5" Background="#2196F3" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="បច្ចុប្បន្នភាពទិន្នន័យ" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ====== CONTENT ====== -->
        <Grid Grid.Row="1" Margin="20,0,20,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Loading -->
                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Height="200">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10" />
                            <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <!-- Subject DataGrid -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                            TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                            Padding="15" CornerRadius="4"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                        <StackPanel>
                            <DataGrid ItemsSource="{Binding Subjects}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="14"
                                      FontFamily="{StaticResource NotoSansKhmer}"
                                      MaxHeight="600">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="ឈ្មោះ (ខ្មែរ)" Binding="{Binding KhmerName}" Width="200"/>
                                    <DataGridTextColumn Header="ឈ្មោះ (អង់គ្លេស)" Binding="{Binding Name}" Width="200"/>
                                    <DataGridTextColumn Header="ពិន្ទុអតិបរមា" Binding="{Binding MaxScore}" Width="120"/>
                                    <DataGridTemplateColumn Width="160" Header="សកម្មភាព"
                                                            Visibility="{Binding DataContext.CanManageSubjects, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Command="{Binding DataContext.EditSubjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="8,3" Margin="2" FontSize="12"
                                                            Background="#FF9800" Foreground="White">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" Margin="0,0,3,0"/>
                                                            <TextBlock Text="កែប្រែ"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteSubjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="8,3" Margin="2" FontSize="12"
                                                            Background="#F44336" Foreground="White">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Margin="0,0,3,0"/>
                                                            <TextBlock Text="លុប"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Loading overlay -->
            <Grid Background="#44000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                        <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
