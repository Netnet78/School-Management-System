<UserControl x:Class="SchoolManagement.Presentation.Features.Subjects.Views.SubjectAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Subjects.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:SubjectAssignmentViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
            </Button>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BookOpenVariant" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="គ្រប់គ្រងមុខវិជ្ជា" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding ClassName, StringFormat='កំពុងកែប្រែមុខវិជ្ជាសម្រាប់៖ {0}'}" FontSize="13" Foreground="#666" Margin="36,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}" 
                    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" 
                    Padding="20" CornerRadius="4" Margin="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <materialDesign:PackIcon Kind="BookOpenVariant" Width="22" Height="22" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" Margin="0,0,8,0"/>
                        <TextBlock Text="ជ្រើសរើសមុខវិជ្ជា និងគ្រូបង្រៀន" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Available Subjects -->
                        <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Background="#FAFAFA">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="មុខវិជ្ជាដែលអាចជ្រើស" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                                    <TextBlock Text="សូមជ្រើសរើសរួចចុចប៊ូតុងបន្ថែម" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding AvailableSubjects}"
                                         SelectedItem="{Binding SelectedAvailableSubject}"
                                         Height="350"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Margin" Value="0,4"/>
                                            <Setter Property="Padding" Value="12,12"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                                <Setter Property="BorderBrush" Value="#2196F3"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding KhmerName}" FontSize="15" FontWeight="SemiBold" Foreground="#333"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Move Buttons -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15">
                            <Button Command="{Binding AddSubjectCommand}" Margin="0,0,0,15"
                                    Width="45" Height="45" Padding="0"
                                    Background="#2196F3" Foreground="White"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                    ToolTip="បន្ថែមមុខវិជ្ជា">
                                <materialDesign:PackIcon Kind="ChevronRight" Width="28" Height="28"/>
                            </Button>
                            <Button Command="{Binding RemoveSubjectCommand}"
                                    Width="45" Height="45" Padding="0"
                                    Background="#F44336" Foreground="White"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                    ToolTip="ដកមុខវិជ្ជាចេញ">
                                <materialDesign:PackIcon Kind="ChevronLeft" Width="28" Height="28"/>
                            </Button>
                        </StackPanel>

                        <!-- Selected Subjects -->
                        <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Background="#FAFAFA">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="មុខវិជ្ជាដែលបានជ្រើស" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                                    <TextBlock Text="មុខវិជ្ជាដែលនឹងត្រូវបង្រៀនក្នុងថ្នាក់នេះ" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding SelectedSubjects}"
                                         SelectedItem="{Binding SelectedSelectedSubject}"
                                         Height="350"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Margin" Value="0,4"/>
                                            <Setter Property="Padding" Value="12,12"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                                <Setter Property="BorderBrush" Value="#2196F3"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <materialDesign:PackIcon Kind="BookOutline" Width="18" Height="18" Foreground="#2196F3" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Subject.KhmerName}" FontSize="15" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ComboBox ItemsSource="{Binding DataContext.Teachers, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          SelectedItem="{Binding SelectedTeacher}"
                                                          DisplayMemberPath="FullName"
                                                          Padding="8" FontSize="14"
                                                          materialDesign:HintAssist.Hint="ជ្រើសរើសគ្រូបង្រៀនមុខវិជ្ជានេះ"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading & Footer -->
        <Grid Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Background="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                <TextBlock Text="កំពុងរក្សាទុក..." HorizontalAlignment="Center" FontSize="16" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
            <Button Command="{Binding CancelCommand}" Margin="5" FontSize="16" Background="Red" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,5,0"/>
                    <TextBlock Text="បោះបង់"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" Margin="5" FontSize="16" Background="#4CAF50" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,5,0"/>
                    <TextBlock Text="រក្សាទុក"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
