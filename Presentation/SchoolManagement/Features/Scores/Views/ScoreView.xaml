<UserControl x:Class="SchoolManagement.Presentation.Features.Scores.Views.ScoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Scores.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ScoreViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocument" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ClassName, StringFormat='ពិន្ទុប្រឡងថ្នាក់៖ {0}'}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ClassInfo}" FontSize="13" Foreground="#666" Margin="36,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,0,20,20">

                <!-- Loading -->
                <Grid Visibility="{Binding IsLoadingStudents, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Height="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10"/>
                        <TextBlock Text="កំពុងទាញទិន្នន័យ..." HorizontalAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </Grid>

                <!-- STUDENT LIST -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                        Padding="15" CornerRadius="4" Margin="0,0,0,20"
                        Visibility="{Binding IsLoadingStudents, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Students.Count, StringFormat='បញ្ជីសិស្ស ({0} នាក់)'}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Students}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  FontSize="14"
                                  FontFamily="{StaticResource NotoSansKhmer}"
                                  MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="ឈ្មោះពេញ" Binding="{Binding FullName}" Width="200"/>
                                <DataGridTextColumn Header="ភេទ" Binding="{Binding Gender}" Width="80"/>
                                <DataGridTextColumn Header="ថ្ងៃខែឆ្នាំកំណើត" Binding="{Binding DateOfBirth}" Width="130"/>
                                <DataGridTextColumn Header="ជំនាញ" Binding="{Binding Skill.KhmerName}" Width="120"/>
                                <DataGridTextColumn Header="ស្ថានភាព" Binding="{Binding IsActiveReadable}" Width="100"/>
                                <DataGridTemplateColumn Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Command="{Binding DataContext.AddScoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3" Margin="2" FontSize="12"
                                                        Background="#4CAF50" Foreground="White">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" Margin="0,0,3,0"/>
                                                        <TextBlock Text="ពិន្ទុ"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- EXAMS & SCORES -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                        Padding="15" CornerRadius="4" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="FileDocument" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="ពិន្ទុប្រឡង" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,10">
                            <TextBlock Text="ជ្រើសរើសប្រឡង:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Exams}"
                                      SelectedItem="{Binding SelectedExam}"
                                      DisplayMemberPath="KhmerName"
                                      Padding="6" FontSize="14"
                                      MinWidth="250"/>
                        </Grid>

                        <Grid Visibility="{Binding IsLoadingScores, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Height="60">
                            <ProgressBar IsIndeterminate="True" Height="20" Width="300"/>
                        </Grid>

                        <DataGrid ItemsSource="{Binding Scores}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  FontSize="14"
                                  FontFamily="{StaticResource NotoSansKhmer}"
                                  MaxHeight="400"
                                  Visibility="{Binding HasScores, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="សិស្ស" Binding="{Binding StudentClass.Student.FullName}" Width="200"/>
                                <DataGridTextColumn Header="មុខវិជ្ជា" Binding="{Binding ClassSubject.Subject.KhmerName}" Width="150"/>
                                <DataGridTextColumn Header="ពិន្ទុ" Binding="{Binding TotalScore}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="មិនទាន់មានពិន្ទុសម្រាប់ប្រឡងនេះទេ។"
                                   FontSize="14" FontStyle="Italic" Margin="0,10,0,0"
                                   Visibility="{Binding HasScores, Converter={StaticResource BooleanToVisibilityConverterReversed}}"/>
                    </StackPanel>
                </Border>

                <!-- ADD SCORE FORM -->
                <Border BorderBrush="#4CAF50"
                        BorderThickness="2" CornerRadius="4" Padding="15" Margin="0,0,0,20"
                        Visibility="{Binding ShowScoreForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="PlusCircle" Width="20" Height="20" Margin="0,0,8,0" Foreground="#4CAF50"/>
                            <TextBlock Text="{Binding ScoreStudentName, StringFormat='បន្ថែមពិន្ទុសម្រាប់៖ {0}'}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <!-- Exam -->
                            <TextBlock Text="ប្រឡង:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <ComboBox Grid.Column="1" Margin="0,0,0,8"
                                      ItemsSource="{Binding Exams}"
                                      SelectedItem="{Binding SelectedScoreExam}"
                                      DisplayMemberPath="KhmerName"
                                      Padding="6" FontSize="14"/>

                            <!-- Subject -->
                            <TextBlock Grid.Row="1" Text="មុខវិជ្ជា:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                                      ItemsSource="{Binding ScoreSubjects}"
                                      SelectedItem="{Binding SelectedScoreSubject}"
                                      DisplayMemberPath="Subject.KhmerName"
                                      Padding="6" FontSize="14"/>

                            <!-- Score Amount -->
                            <TextBlock Grid.Row="2" Text="ពិន្ទុ:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                                     Text="{Binding ScoreAmount}"
                                     Padding="6" FontSize="14" Width="120" HorizontalAlignment="Left"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Button Command="{Binding CancelScoreCommand}"
                                    Margin="5" FontSize="14" Background="#9E9E9E" Foreground="White">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Margin="0,0,3,0"/>
                                    <TextBlock Text="បោះបង់"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SaveScoreCommand}"
                                    Margin="5" FontSize="14" Background="#4CAF50" Foreground="White">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,3,0"/>
                                    <TextBlock Text="រក្សាទុក"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Grid Visibility="{Binding IsSavingScore, Converter={StaticResource BooleanToVisibilityConverter}}" Height="30">
                            <ProgressBar IsIndeterminate="True" Height="20"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- REPORT -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                        Padding="15" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="របាយការណ៍" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="បង្កើតរបាយការណ៍សង្ខេបពីពិន្ទុសិស្សក្នុងថ្នាក់" FontSize="14" Margin="0,0,0,10"/>
                        <Button Command="{Binding GenerateReportCommand}"
                                Padding="12,6" FontSize="14"
                                Background="#2196F3" Foreground="White"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileChart" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="បង្កើតរបាយការណ៍"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Grid.Row="1" Background="#44000000"
              Visibility="{Binding IsLoadingStudents, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
