<UserControl x:Class="SchoolManagement.Presentation.Features.Scores.Views.ScoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Scores.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ScoreViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== HEADER ====== -->
        <StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocument" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="បញ្ចូលពិន្ទុប្រឡង" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ClassInfo}" FontSize="13" Foreground="#666" Margin="36,4,0,0"
                               Visibility="{Binding IsScoreEntryMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- ====== CONTENT ====== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,0,20,20">

                <!-- ====== CLASS SELECTION MODE ====== -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                        Padding="20" CornerRadius="4"
                        Visibility="{Binding IsClassSelectionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <materialDesign:PackIcon Kind="School" Width="22" Height="22" Margin="0,0,8,0"/>
                            <TextBlock Text="ជ្រើសរើសថ្នាក់" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>

                        <Grid Visibility="{Binding IsLoadingClasses, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Height="60">
                            <ProgressBar IsIndeterminate="True" Height="20" Width="300"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,10"
                              Visibility="{Binding IsLoadingClasses, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                            <TextBlock Text="ថ្នាក់:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Classes}"
                                      SelectedItem="{Binding SelectedClass}"
                                      DisplayMemberPath="KhmerName"
                                      Padding="6" FontSize="14"
                                      MinWidth="300"
                                      materialDesign:HintAssist.Hint="ជ្រើសរើសថ្នាក់"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ====== SCORE ENTRY MODE ====== -->
                <StackPanel Visibility="{Binding IsScoreEntryMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <!-- Class info bar -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                            TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                            Padding="15" CornerRadius="4" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ChangeClassCommand}"
                                    Padding="8,4" Margin="0,0,10,0"
                                    Background="#FF9800" Foreground="White" FontSize="13"
                                    ToolTip="ប្តូរថ្នាក់">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SwapHorizontal" Width="16" Height="16" Margin="0,0,4,0"/>
                                    <TextBlock Text="ប្តូរថ្នាក់"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding ClassName, StringFormat='ថ្នាក់: {0}'}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Subject & Exam selection -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                            TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                            Padding="15" CornerRadius="4" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="FilterVariant" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="ជ្រើសរើសមុខវិជ្ជា និងប្រឡង" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto">
                                <!-- Subject -->
                                <TextBlock Text="មុខវិជ្ជា:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="1" Margin="0,0,20,0"
                                          ItemsSource="{Binding ScoreSubjects}"
                                          SelectedItem="{Binding SelectedScoreSubject}"
                                          DisplayMemberPath="Subject.KhmerName"
                                          Padding="6" FontSize="14" MinWidth="250"/>

                                <!-- Exam -->
                                <TextBlock Grid.Column="2" Text="ប្រឡង:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="3"
                                          ItemsSource="{Binding Exams}"
                                          SelectedItem="{Binding SelectedExam}"
                                          DisplayMemberPath="KhmerName"
                                          Padding="6" FontSize="14" MinWidth="250"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bulk scores grid -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                            TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                            Padding="15" CornerRadius="4" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ScoreEntries.Count, StringFormat='បញ្ចូលពិន្ទុសិស្ស ({0} នាក់)'}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Loading -->
                            <Grid Visibility="{Binding IsLoadingScores, Converter={StaticResource BooleanToVisibilityConverter}}" Height="60">
                                <ProgressBar IsIndeterminate="True" Height="20" Width="300"/>
                            </Grid>

                            <!-- Hint to select subject + exam -->
                            <TextBlock Text="សូមជ្រើសរើសមុខវិជ្ជា និងប្រឡងដើម្បីចាប់ផ្តើម"
                                       FontSize="14" FontStyle="Italic" Margin="0,10,0,0"
                                       Visibility="{Binding HasScores, Converter={StaticResource BooleanToVisibilityConverterReversed}}"/>

                            <!-- Scores DataGrid -->
                            <DataGrid ItemsSource="{Binding ScoreEntries}"
                                      Margin="0 10 0 0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      FontSize="14"
                                      FontFamily="{StaticResource NotoSansKhmer}"
                                      MaxHeight="500"
                                      Visibility="{Binding IsLoadingScores, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ឈ្មោះសិស្ស" Binding="{Binding Student.FullName}" Width="250" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="ពិន្ទុដែលមានស្រាប់" Binding="{Binding ExistingAssessment.TotalScore}" Width="150" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="បញ្ចូលពិន្ទុ" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ScoreAmount, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="4" FontSize="14" Width="100" HorizontalAlignment="Left"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Save All button -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0"
                                        Visibility="{Binding IsLoadingScores, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                                <Button Command="{Binding SaveAllCommand}"
                                        Padding="12,6" FontSize="14"
                                        Background="#4CAF50" Foreground="White">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0"/>
                                        <TextBlock Text="រក្សាទុកទាំងអស់"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Saving indicator -->
                            <Grid Visibility="{Binding IsSavingScores, Converter={StaticResource BooleanToVisibilityConverter}}" Height="30" Margin="0,10,0,0">
                                <ProgressBar IsIndeterminate="True" Height="20"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Report -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                            TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                            Padding="15" CornerRadius="4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="របាយការណ៍" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="បង្កើតរបាយការណ៍សង្ខេបពីពិន្ទុសិស្ស" FontSize="14" Margin="0,0,0,10"/>
                            <Button Command="{Binding GenerateReportCommand}"
                                    Padding="12,6" FontSize="14"
                                    Background="#2196F3" Foreground="White"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileChart" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="បង្កើតរបាយការណ៍"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Grid.Row="1" Background="#44000000"
              Visibility="{Binding IsSavingScores, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="កំពុងរក្សាទុក..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
