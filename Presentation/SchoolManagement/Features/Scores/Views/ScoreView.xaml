<UserControl x:Class="SchoolManagement.Presentation.Features.Scores.Views.ScoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Scores.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ScoreViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100"
             DataContextChanged="OnDataContextChanged">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== HEADER ====== -->
        <StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocument" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="бһ”бһүбҹ’бһ…бһјбһӣбһ–бһ·бһ“бҹ’бһ‘бһ»бһ”бҹ’бһҡбһЎбһ„" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ClassInfo}" FontSize="13" Foreground="#666" Margin="36,4,0,0"
                               Visibility="{Binding IsScoreEntryMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- ====== CONTENT ====== -->
        <Grid Grid.Row="1">
            
            <!-- ====== CLASS SELECTION MODE ====== -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                    Padding="20" CornerRadius="4" Margin="20"
                    VerticalAlignment="Top"
                    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                    Visibility="{Binding IsClassSelectionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <materialDesign:PackIcon Kind="School" Width="22" Height="22" Margin="0,0,8,0"/>
                        <TextBlock Text="бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҗбҹ’бһ“бһ¶бһҖбҹӢ" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <Grid Visibility="{Binding IsLoadingClasses, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Height="60">
                        <ProgressBar IsIndeterminate="True" Height="20" Width="300"/>
                    </Grid>

                    <!-- Class Cards Gallery -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600"
                                  Visibility="{Binding IsLoadingClasses, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                        <ListBox ItemsSource="{Binding Classes}"
                                 SelectedItem="{Binding SelectedClass}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#15FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="210" MinHeight="110"
                                        CornerRadius="8"
                                        Background="White"
                                        BorderBrush="#D0D0D0"
                                        BorderThickness="1"
                                        Padding="14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="32" Height="32" CornerRadius="6"
                                                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                                    VerticalAlignment="Top" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="SchoolOutline"
                                                                         Width="18" Height="18"
                                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Grade.KhmerName}"
                                                       FontSize="17" FontWeight="Bold"
                                                       Foreground="#222"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Generation.Department.KhmerName}"
                                                   FontSize="13" Foreground="#666"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock FontSize="12" Foreground="#999">
                                            <Run Text="бһҮбҹҶбһ“бһ¶бһ“бҹӢбһ‘бһё"/>
                                            <Run Text="{Binding Generation.CohortNumber}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- ====== SCORE ENTRY MODE ====== -->
            <Grid Visibility="{Binding IsScoreEntryMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP TOOLBAR -->
                <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Change Class / Name -->
                            <ColumnDefinition Width="Auto"/> <!-- Separator -->
                            <ColumnDefinition Width="Auto"/> <!-- Subject -->
                            <ColumnDefinition Width="Auto"/> <!-- Exam -->
                            <ColumnDefinition Width="*"/>    <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/> <!-- Report -->
                            <ColumnDefinition Width="Auto"/> <!-- Save -->
                        </Grid.ColumnDefinitions>

                        <!-- Class Info -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding ChangeClassCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    ToolTip="бһ”бҹ’бһҸбһјбһҡбһҗбҹ’бһ“бһ¶бһҖбҹӢ" Margin="0,0,10,0" Padding="4">
                                <materialDesign:PackIcon Kind="SwapHorizontal" Width="24" Height="24" Foreground="#FF9800"/>
                            </Button>
                            <TextBlock Text="{Binding ClassName, StringFormat='бһҗбҹ’бһ“бһ¶бһҖбҹӢ: {0}'}" FontSize="18" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="1" Width="1" Background="#D0D0D0" Margin="15,5"/>

                        <!-- Subject -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="бһҳбһ»бһҒбһңбһ·бһҮбҹ’бһҮбһ¶:" FontSize="15" Foreground="#666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding ScoreSubjects}"
                                      SelectedItem="{Binding SelectedScoreSubject}"
                                      DisplayMemberPath="Subject.KhmerName"
                                      materialDesign:HintAssist.Hint="бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҳбһ»бһҒбһңбһ·бһҮбҹ’бһҮбһ¶"
                                      Width="220" FontSize="15" Padding="6"/>
                        </StackPanel>

                        <!-- Exam -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="бһ”бҹ’бһҡбһЎбһ„:" FontSize="15" Foreground="#666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding Exams}"
                                      SelectedItem="{Binding SelectedExam}"
                                      DisplayMemberPath="KhmerName"
                                      materialDesign:HintAssist.Hint="бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһ”бҹ’бһҡбһЎбһ„"
                                      Width="220" FontSize="15" Padding="6"/>
                        </StackPanel>

                        <!-- Actions -->
                        <Button Grid.Column="5" Command="{Binding GenerateReportCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#2196F3" Foreground="#2196F3"
                                Margin="15,0,15,0" Padding="12,6" Height="38">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileChartOutline" Width="20" Height="20" Margin="0,0,6,0"/>
                                <TextBlock Text="бһҡбһ”бһ¶бһҷбһҖбһ¶бһҡбһҺбҹҚ" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Grid.Column="6" Command="{Binding SaveAllCommand}"
                                Background="#4CAF50" Foreground="White" BorderThickness="0"
                                Padding="16,6" Height="38"
                                IsEnabled="{Binding HasScores}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20" Margin="0,0,6,0"/>
                                <TextBlock Text="бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- WORKSPACE CONTENT -->
                <Grid Grid.Row="1" Background="White">
                    
                    <!-- Loading overlay for Scores -->
                    <Grid Panel.ZIndex="10" Background="#99FFFFFF" Visibility="{Binding IsLoadingScores, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                            <TextBlock Text="бһҖбҹҶбһ–бһ»бһ„бһ‘бһ¶бһүбһҷбһҖбһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷ..." FontSize="16" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Empty State Placeholder -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasScores, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                        <materialDesign:PackIcon Kind="ClipboardTextSearchOutline" Width="100" Height="100" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="бһҹбһјбһҳбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҳбһ»бһҒбһңбһ·бһҮбҹ’бһҮбһ¶ бһ“бһ·бһ„бһ”бҹ’бһҡбһЎбһ„" FontSize="22" FontWeight="Bold" Foreground="#78909C" HorizontalAlignment="Center"/>
                        <TextBlock Text="бһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷбһ–бһ·бһ“бҹ’бһ‘бһ»бһ“бһ№бһ„бһ”бһ„бҹ’бһ бһ¶бһүбһ“бҹ…бһ‘бһёбһ“бҹҒбҹҮбһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһ–бһёбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҡбһҪбһ…" FontSize="15" Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid x:Name="ScoreGrid"
                              ItemsSource="{Binding ScoreEntries}"
                              Visibility="{Binding HasScores, Converter={StaticResource BooleanToVisibilityConverter}}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              FontSize="15"
                              FontFamily="{StaticResource NotoSansKhmer}"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="#E0E0E0"
                              VerticalGridLinesBrush="#E0E0E0"
                              RowHeight="50"
                              BorderThickness="0"
                              Background="White"
                              AlternatingRowBackground="#F8F9FA"
                              CanUserSortColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionUnit="Cell"
                              SelectionMode="Single"
                              PreviewKeyDown="ScoreGrid_PreviewKeyDown">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="Background" Value="#F1F3F4"/>
                                <Setter Property="Foreground" Value="#222"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="Foreground" Value="#000"/>
                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Loading overlay -->
        <Grid Grid.Row="1" Background="#44000000"
              Visibility="{Binding IsSavingScores, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="бһҖбҹҶбһ–бһ»бһ„бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
