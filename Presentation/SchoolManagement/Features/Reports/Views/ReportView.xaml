<UserControl x:Class="SchoolManagement.Presentation.Features.Reports.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Reports.ViewModels"
             xmlns:models="clr-namespace:SchoolManagement.Presentation.Features.Reports.Models"
             xmlns:infraExport="clr-namespace:SchoolManagement.Infrastructure.Features.Reports.Contracts;assembly=SchoolManagement.Infrastructure"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:ReportViewModel}"
             Background="{DynamicResource MaterialDesignPaper}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True"/>
        <conv:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Collapse="True" IsReversed="True"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" CollapseWhenNull="True"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Report" Width="32" Height="32" VerticalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <TextBlock Text="មើលរបាយការណ៍" FontSize="24" FontWeight="Bold"
                           Margin="10 0 0 0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding SelectedReportTitle, FallbackValue=''}"
                       FontSize="18" VerticalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- Report Type Cards -->
        <ScrollViewer Grid.Row="1"
              VerticalScrollBarVisibility="Disabled"
              HorizontalScrollBarVisibility="Disabled"
              Margin="0 0 0 15">

            <ItemsControl ItemsSource="{Binding ReportCards}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ReportCardItem}">

                        <Border Width="200"
                    MinHeight="120"
                    Margin="0 0 10 10"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    Cursor="Hand">

                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <StackPanel>

                                <materialDesign:PackIcon Kind="{Binding IconKind}"
                                             Width="32"
                                             Height="32"
                                             Foreground="White"
                                             HorizontalAlignment="Center"/>

                                <TextBlock Text="{Binding DisplayName}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0 8 0 0"/>

                                <TextBlock Text="{Binding DisplayNameEn}"
                               FontSize="11"
                               Foreground="White"
                               Opacity="0.8"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0 4 0 0"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>
        <!-- Filter Section -->
        <Border Grid.Row="2" Margin="0 0 0 10" Padding="10"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                BorderThickness="1" CornerRadius="4"
                Visibility="{Binding IsFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ContentControl Content="{Binding CurrentFilterViewModel}"/>
        </Border>

        <!-- Loading Indicator -->
        <Grid Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                <TextBlock Text="កំពុងដំណើរការ..." FontSize="16" Margin="0 10 0 0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Card Preview -->
        <ScrollViewer Grid.Row="3"
                      Visibility="{Binding HasCardPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding CardPreviewGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:CardPreviewGroup}">
                        <Border Width="{Binding Width}" Height="{Binding Height}"
                                Margin="4" Padding="6"
                                BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                BorderThickness="1" CornerRadius="4"
                                Background="{DynamicResource MaterialDesignPaper}">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:CardPreviewItem}">
                                        <Grid>
                                            <TextBlock Text="{Binding Text}"
                                                       Visibility="{Binding ImageBytes, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=isreversed}"
                                                       FontSize="10" TextWrapping="Wrap"/>
                                            <Image Source="{Binding ImageSource}"
                                                   Width="50" Height="50"
                                                   Visibility="{Binding ImageBytes, Converter={StaticResource NullToVisibilityConverter}}"
                                                   Stretch="Uniform"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Preview DataGrid -->
        <Grid Grid.Row="3"
              Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DataGrid ItemsSource="{Binding PreviewTable}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      FontSize="12"
                      RowHeaderWidth="0"
                      Background="{DynamicResource MaterialDesignPaper}"
                      BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}"
                      BorderThickness="1">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            </DataGrid>
        </Grid>

        <!-- No Data Message -->
        <TextBlock Grid.Row="3"
                   Text="សូមជ្រើសរើសប្រភេទរបាយការណ៍ និងកំណត់តម្រង"
                   FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding ShowNoDataMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                   Opacity="0.5"/>

        <!-- Summary Row -->
        <Border Grid.Row="4" Margin="0 10 0 0" Padding="8"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Visibility="{Binding HasSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding SummaryText}"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                       FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <!-- Export Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0 10 0 0"
                    Visibility="{Binding HasSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Exporters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type infraExport:IReportExporter}">
                        <Button Command="{Binding DataContext.ExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Margin="0 0 10 0"
                                Height="40" Width="160">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileExport"
                                                         Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding FormatName, StringFormat='Export {0}'}"
                                           Margin="8 0 0 0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
