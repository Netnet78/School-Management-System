<UserControl x:Class="SchoolManagement.Presentation.Features.Reports.Views.ReportTablePreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SchoolManagement.Presentation.Features.Reports.Models"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis" Collapse="True"/>
        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ReportDataGrid" ItemsSource="{Binding TableData.Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  RowHeaderWidth="0"
                  Background="{DynamicResource MaterialDesignPaper}"
                  BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}"
                  BorderThickness="1">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
                    <Setter Property="FontSize" Value="16" />
                </Style>
            </DataGrid.CellStyle>
        </DataGrid>

        <Border Grid.Row="1" Margin="0 8 0 0" Padding="6"
                Visibility="{Binding TableData.HasSelection, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding GoToPreviousPageCommand}"
                        Padding="8 4" Margin="0 0 6 0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="◀" Margin="0 0 4 0"/>
                        <TextBlock Text="ថយក្រោយ"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding PageInfo}"
                           VerticalAlignment="Center"
                           Margin="10 0"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <Button Command="{Binding GoToNextPageCommand}"
                        Padding="8 4" Margin="6 0 0 0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="បន្ទាប់"/>
                        <TextBlock Text=" ▶" Margin="4 0 0 0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
