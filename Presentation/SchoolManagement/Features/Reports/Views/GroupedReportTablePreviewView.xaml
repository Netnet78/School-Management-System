<UserControl x:Class="SchoolManagement.Presentation.Features.Reports.Views.GroupedReportTablePreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,2"/>
        </Style>

        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True"/>
    </UserControl.Resources>

    <TabControl x:Name="GroupTabControl"
                VirtualizingPanel.IsVirtualizing="True"
                Visibility="{Binding GroupedTableData.HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
    </TabControl>
</UserControl>
