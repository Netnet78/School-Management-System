<UserControl x:Class="SchoolManagement.Presentation.Features.Roles.Views.RoleManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Roles.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root"
             d:DataContext="{d:DesignInstance Type=viewmodels:RoleManagementViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" Collapse="True" IsReversed="True" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" CollapseWhenNull="True"/>
    </UserControl.Resources>

    <Grid Background="White" TextElement.FontFamily="{StaticResource NotoSansKhmer}" TextElement.FontSize="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <TextBlock Text="គ្រប់គ្រងតួនាទី" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Command="{Binding ToggleAddNewRoleCommand}"
                    Padding="10,5"
                    Margin="20,0,0,0"
                    Background="#4CAF50"
                    Foreground="White"
                    IsEnabled="{Binding CanManageRoles}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,5,0" />
                    <TextBlock Text="បន្ថែមតួនាទី" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Role List -->
            <Border Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="បញ្ជីតួនាទី" FontSize="18" FontWeight="Bold" Margin="8,8,8,12" />

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole}"
                              FontSize="16">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="14" Opacity=".7" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Role Details -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="សូមជ្រើសរើសតួនាទីណាមួួយពីបញ្ជី"
                                   FontSize="18"
                                   Opacity=".5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,40,0,0"
                                   Visibility="{Binding SelectedRole, Converter={StaticResource NullToVisibilityConverter},
                                    ConverterParameter='isreversed'}" />

                        <StackPanel Visibility="{Binding SelectedRole, Converter={StaticResource NullToVisibilityConverter}}">
                            <Border Background="#F5F5F5" Padding="12" Margin="0,0,0,12" CornerRadius="4">
                                <Grid ColumnDefinitions="*,*,Auto">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="ឈ្មោះតួនាទី" Margin="0,0,0,4" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding EditingRoleName, UpdateSourceTrigger=PropertyChanged}" Padding="8" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="ការពិពណ៌នា" Margin="0,0,0,4" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding EditingRoleDescription, UpdateSourceTrigger=PropertyChanged}" Padding="8" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding SaveEditRoleCommand}"
                                            Padding="10,6"
                                            Margin="10,18,0,0"
                                            Background="#2196F3"
                                            Foreground="White"
                                            VerticalAlignment="Bottom"
                                            IsEnabled="{Binding CanManageRoles}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="រក្សាទុក" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <Border Background="#F5F5F5" Padding="12" Margin="0,0,0,12" CornerRadius="4">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="ShieldCheck" Width="18" Height="18" Margin="0,0,6,0" />
                                        <TextBlock Text="ការអនុញ្ញាត" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding PermissionItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Margin="4,6"
                                                          IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                                          Content="{Binding Name}"
                                                          FontSize="15"
                                                          IsEnabled="{Binding DataContext.CanManageRoles, Source={x:Reference Root}}">
                                                    <CheckBox.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                                      Command="{Binding DataContext.TogglePermissionCommand, Source={x:Reference Root}}"
                                                                      CommandParameter="{Binding}" />
                                                    </CheckBox.InputBindings>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Button Command="{Binding DeleteRoleCommand}"
                                    CommandParameter="{Binding SelectedRole}"
                                    Padding="10,6"
                                    Background="#F44336"
                                    Foreground="White"
                                    HorizontalAlignment="Left"
                                    IsEnabled="{Binding CanManageRoles}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Margin="0,0,4,0" />
                                    <TextBlock Text="លុបតួនាទី" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Background="#F5F5F5"
                                Padding="12"
                                Margin="0,12,0,0"
                                CornerRadius="4"
                                Visibility="{Binding IsAddingNewRole, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="បន្ថែមតួនាទីថ្មី" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="18" />
                                <Grid ColumnDefinitions="*,*,Auto">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="ឈ្មោះតួនាទី" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}" Padding="8" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="ការពិពណ៌នា" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding NewRoleDescription, UpdateSourceTrigger=PropertyChanged}" Padding="8" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding AddRoleCommand}"
                                            Padding="10,6"
                                            Margin="10,18,0,0"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            VerticalAlignment="Bottom"
                                            IsEnabled="{Binding CanManageRoles}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="បន្ថែម" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#44000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" />
                <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
