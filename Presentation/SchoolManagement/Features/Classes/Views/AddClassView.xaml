<UserControl x:Class="SchoolManagement.Presentation.Features.Classes.Views.AddClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Classes.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:AddClassViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
            </Button>
            <TextBlock Text="បន្ថែមថ្នាក់ថ្មី" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}" 
                    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" 
                    Padding="20" CornerRadius="4" Margin="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <materialDesign:PackIcon Kind="School" Width="22" Height="22" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" Margin="0,0,8,0"/>
                        <TextBlock Text="ព័ត៌មានថ្នាក់" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" TextElement.FontFamily="{StaticResource NotoSansKhmer}">
                        <!-- Department (Admin only) -->
                        <StackPanel Margin="0,0,0,12"
                                    Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="ផ្នែក" FontSize="16" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DepartmentsForForm}"
                                      SelectedItem="{Binding SelectedDepartment}"
                                      DisplayMemberPath="KhmerName"
                                      Padding="8" FontSize="16"/>
                        </StackPanel>

                        <!-- Grade -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock Text="កម្រិត" FontSize="16" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Grades}"
                                      SelectedItem="{Binding SelectedGrade}"
                                      DisplayMemberPath="KhmerName"
                                      Padding="8" FontSize="16"/>
                        </StackPanel>

                        <!-- Generation -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,12">
                            <TextBlock Text="ជំនាន់" FontSize="16" Margin="0,0,0,4"/>
                            <Grid RowDefinitions="*" ColumnDefinitions=".8*, .2*">
                                <ComboBox ItemsSource="{Binding Generations}"
                                      SelectedItem="{Binding SelectedGeneration}"
                                      DisplayMemberPath="CohortNumber"
                                      Padding="8" FontSize="16"/>
                                <Button Grid.Column="1" Margin="10 0 0 0" 
                                        Command="{Binding AddGenerationCommand}"
                                        Background="{DynamicResource MaterialDesign.Brush.Primary}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Add" />
                                        <TextBlock Text="បន្ថែមជំនាន់"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Inline Add Generation Form -->
                            <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" 
                                    BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,10,0,0"
                                    Visibility="{Binding ShowGenerationForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="បន្ថែមជំនាន់ថ្មី" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,8">
                                            <TextBlock Text="លេខជំនាន់" FontSize="14" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding CohortNumber}" Padding="6" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,5,8">
                                            <TextBlock Text="ឆ្នាំចាប់ផ្ដើម" FontSize="14" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding AcademicStartYear}" Padding="6" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="5,0,0,8">
                                            <TextBlock Text="ឆ្នាំបញ្ចប់" FontSize="14" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding AcademicEndYear}" Padding="6" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                                        <Button Command="{Binding CancelGenerationCommand}" Margin="5" FontSize="14" Background="Red" Foreground="White">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Margin="0,0,3,0"/>
                                                <TextBlock Text="បោះបង់"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding SaveGenerationCommand}" Margin="5" FontSize="14" Background="#4CAF50" Foreground="White">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,3,0"/>
                                                <TextBlock Text="រក្សាទុក"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Teacher -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,12">
                            <TextBlock Text="គ្រូបង្រៀន" FontSize="16" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Teachers}"
                                      SelectedItem="{Binding SelectedTeacher}"
                                      DisplayMemberPath="FullName"
                                      Padding="8" FontSize="16"/>
                        </StackPanel>
                    </Grid>

                    <!-- Note: Subjects can be assigned after saving the class -->
                    <Border Background="#FFF3CD" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Information" Width="18" Height="18" Foreground="#856404" Margin="0,0,8,0"/>
                                <TextBlock Text="ចំណាំ" FontSize="16" FontWeight="Bold" Foreground="#856404"/>
                            </StackPanel>
                            <TextBlock Text="1. សូមធ្វើការជ្រើសរើសផ្នែកណាមួយសិន មុននឹងចាប់ផ្ដើមជ្រើសរើសជំនាន់" Margin="0,5,0,0" FontSize="14" Foreground="#856404"/>
                            <TextBlock Text="2. ប្រសិនបើជំនាន់សិស្សមិនទាន់មាន សូមធ្វើការបង្កើតជំនាន់ថ្មីដោយចុចលើប៊ូតុង បន្ថែមជំនាន់" Margin="0,5,0,0" FontSize="14" Foreground="#856404"/>
                            <TextBlock Text="3. មុខវិជ្ជាអាចជ្រើសរើសបានបន្ទាប់ពីរក្សាទុកថ្នាក់រួច" Margin="0,5,0,0" FontSize="14" Foreground="#856404"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading & Footer -->
        <Grid Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Background="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                <TextBlock Text="កំពុងរក្សាទុក..." HorizontalAlignment="Center" FontSize="16" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
            <Button Command="{Binding CancelCommand}" Margin="5" FontSize="16" Background="Red" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,5,0"/>
                    <TextBlock Text="បោះបង់"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" Margin="5" FontSize="16" Background="#4CAF50" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,5,0"/>
                    <TextBlock Text="រក្សាទុក"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
