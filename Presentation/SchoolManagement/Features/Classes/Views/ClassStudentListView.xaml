<UserControl x:Class="SchoolManagement.Presentation.Features.Classes.Views.ClassStudentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Classes.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ClassStudentListViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
                </Button>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ClassName, StringFormat='សិស្សក្នុងថ្នាក់៖ {0}'}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ClassInfo}" FontSize="13" Foreground="#666" Margin="36,4,0,0"/>
                </StackPanel>

                <!-- Navigation buttons -->
                <Button Command="{Binding ShowScoresCommand}"
                        Padding="10,5" Margin="20,0,0,0"
                        Background="#4CAF50" Foreground="White"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocument" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="ពិន្ទុប្រឡង" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,0,20,20">

                <!-- Loading -->
                <Grid Visibility="{Binding IsLoadingStudents, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Height="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10"/>
                        <TextBlock Text="កំពុងទាញទិន្នន័យសិស្ស..." HorizontalAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </Grid>

                <!-- STUDENT LIST -->
                <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                        Padding="15" CornerRadius="4" Margin="0,0,0,20"
                        Visibility="{Binding IsLoadingStudents, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Students.Count, StringFormat='បញ្ជីសិស្ស ({0} នាក់)'}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Students}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  FontSize="14"
                                  FontFamily="{StaticResource NotoSansKhmer}"
                                  MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="ឈ្មោះពេញ" Binding="{Binding FullName}" Width="200"/>
                                <DataGridTextColumn Header="ភេទ" Binding="{Binding Gender}" Width="80"/>
                                <DataGridTextColumn Header="ថ្ងៃខែឆ្នាំកំណើត" Binding="{Binding DateOfBirth}" Width="130"/>
                                <DataGridTextColumn Header="ជំនាញ" Binding="{Binding Skill.KhmerName}" Width="120"/>
                                <DataGridTextColumn Header="ស្ថានភាព" Binding="{Binding IsActiveReadable}" Width="100"/>
                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Command="{Binding DataContext.EditStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3" Margin="2" FontSize="12"
                                                        Background="#FF9800" Foreground="White"
                                                        Visibility="{Binding DataContext.CanEditStudents, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Edit" Width="14" Height="14" Margin="0,0,3,0"/>
                                                        <TextBlock Text="កែប្រែ"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Grid.Row="1" Background="#44000000"
              Visibility="{Binding IsLoadingStudents, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
