<UserControl x:Class="SchoolManagement.Presentation.Features.Classes.Views.ClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Classes.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ClassViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
        <conv:BooleanInverseConverter x:Key="BooleanInverseConverter" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ====== HEADER ====== -->
        <StackPanel Grid.Row="0" Margin="20" Orientation="Horizontal" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="បញ្ជី​ថ្នាក់រៀន" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="គ្រប់គ្រងថ្នាក់រៀន និងផ្នែក" FontSize="13" Foreground="#666" Margin="0,4,0,0" />
            </StackPanel>

            <Button Command="{Binding AddClassCommand}"
                    Padding="10,5"
                    Margin="20,0,0,0"
                    Background="#4CAF50"
                    Foreground="White"
                    Visibility="{Binding CanInsertClasses, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="បន្ថែមថ្នាក់" />
                </StackPanel>
            </Button>

            <Button Command="{Binding ManageDepartmentsCommand}"
                    Padding="10,5"
                    Margin="10,0,0,0"
                    Background="#FF9800"
                    Foreground="White"
                    Visibility="{Binding CanManageDepartments, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Domain" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="គ្រប់គ្រងផ្នែក" />
                </StackPanel>
            </Button>

            <Button Command="{Binding RefreshCommand}"
                    Padding="10,5"
                    Margin="10,0,0,0"
                    Background="#2196F3"
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="ច្រោះទិន្នន័យសារថ្មី" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ====== CONTENT ====== -->
        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,0,20,20">
                <StackPanel>
                    <!-- Loading indicator -->
                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Height="200">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10" />
                            <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <!-- ====== CLASS DATA GRID ====== -->
                    <DataGrid ItemsSource="{Binding Classes}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontSize="16"
                              FontFamily="{StaticResource NotoSansKhmer}"
                              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell" x:Key="StudentGridCellStyle">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                            <DataGridTextColumn Header="ឈ្មោះថ្នាក់" Binding="{Binding KhmerName}" Width="240" />
                            <DataGridTextColumn Header="កម្រិត" Binding="{Binding Grade.KhmerName}" Width="130" />
                            <DataGridTextColumn Header="ជំនាន់" Binding="{Binding Generation.CohortNumber, StringFormat='ទី{0}'}" Width="80" />
                            <DataGridTextColumn Header="ផ្នែក" Binding="{Binding Generation.Department.KhmerName}" Width="150" />
                            <DataGridTextColumn Header="គ្រូបន្ទុកថ្នាក់" Binding="{Binding Teacher.FullName}" Width="180" />
                            <DataGridTemplateColumn Width="280" Header="ការកំណត់">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.ShowStudentsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,3" Margin="2" FontSize="12"
                                                    Background="#2196F3" Foreground="White"
                                                    Visibility="{Binding DataContext.CanViewClasses, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="AccountGroup" Width="14" Height="14" Margin="0,0,3,0" />
                                                    <TextBlock Text="មើលសិស្ស" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.EditClassCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,3" Margin="2" FontSize="12"
                                                    Background="#FF9800" Foreground="White"
                                                    Visibility="{Binding DataContext.CanEditClasses, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Edit" Width="14" Height="14" Margin="0,0,3,0" />
                                                    <TextBlock Text="កែប្រែ" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteClassCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,3" Margin="2" FontSize="12"
                                                    Background="#F44336" Foreground="White"
                                                    Visibility="{Binding DataContext.CanDeleteClasses, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Margin="0,0,3,0" />
                                                    <TextBlock Text="លុប" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ====== PERMISSION DENIED ====== -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0"
                                Visibility="{Binding CanViewClasses, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                        <TextBlock Text="មិនអនុញ្ញាត​ឱ្យ​ចូលប្រើប្រាស់" FontSize="20" FontWeight="Bold" Foreground="Red" Margin="0,0,0,10" />
                        <TextBlock Text="អ្នកគ្មានសិទ្ធិគ្រប់គ្រាន់ក្នុងការមើលថ្នាក់រៀនទេ!" FontSize="14" TextAlignment="Center" />
                    </StackPanel>


                </StackPanel>
            </ScrollViewer>

            <!-- Loading overlay -->
            <Grid Background="#44000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="20" />
                        <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
