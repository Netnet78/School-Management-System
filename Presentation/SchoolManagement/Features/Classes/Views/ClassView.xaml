<UserControl x:Class="SchoolManagement.Presentation.Features.Classes.Views.ClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Classes.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ClassViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20" Orientation="Horizontal" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="បញ្ជី​ថ្នាក់រៀន" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Teachers see their own classes, head teachers see classes in their department, and admins see everything."
                           FontSize="13"
                           Foreground="#666"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Command="{Binding RefreshCommand}"
                    Padding="10,5"
                    Margin="20,0,0,0"
                    Background="#2196F3"
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="ច្រោះទិន្នន័យសារថ្មី" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10" />
                    <TextBlock Text="Loading classes..." HorizontalAlignment="Center" FontSize="16" />
                </StackPanel>
            </Grid>

            <DataGrid ItemsSource="{Binding Classes}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      FontSize="15"
                      FontFamily="{StaticResource NotoSansKhmer}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
                    <DataGridTextColumn Header="ឈ្មោះថ្នាក់" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="កម្រិត" Binding="{Binding Grade.Name}" Width="140" />
                    <DataGridTextColumn Header="ជំនាន់" Binding="{Binding Generation.CohortNumber}" Width="100" />
                    <DataGridTextColumn Header="ផ្នែក" Binding="{Binding Generation.Department.Name}" Width="150" />
                    <DataGridTextColumn Header="គ្រូបង្រៀន" Binding="{Binding Teacher.FullName}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding CanViewClasses, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                <TextBlock Text="មិនអនុញ្ញាត​ឱ្យ​ចូលប្រើប្រាស់" FontSize="20" FontWeight="Bold" Foreground="Red" Margin="0,0,0,10" />
                <TextBlock Text="អ្នកគ្មានសិទ្ធិគ្រប់គ្រាន់ក្នុងការមើលថ្នាក់រៀនទេ!" FontSize="14" TextAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
