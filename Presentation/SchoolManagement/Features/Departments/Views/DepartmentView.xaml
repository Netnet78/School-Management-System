<UserControl x:Class="SchoolManagement.Presentation.Features.Departments.Views.DepartmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Departments.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:DepartmentViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
        <conv:BooleanInverseConverter x:Key="BooleanInverseConverter" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"/>
            </Button>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Domain" Width="26" Height="26" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="ទម្រង់​គ្រប់គ្រងផ្នែក" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="បន្ថែម កែប្រែ លុប ផ្នែកនានា" FontSize="16" Foreground="#666" Margin="36,4,0,0"/>
            </StackPanel>

            <Button Command="{Binding AddDepartmentCommand}"
                    Padding="10,5" Margin="20,0,0,0"
                    Background="#4CAF50" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="បន្ថែមផ្នែក" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20,0,20,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Loading -->
                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Height="200">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10" />
                            <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <!-- Department DataGrid -->
                    <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                            TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                            Padding="15" CornerRadius="4"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="Domain" Width="20" Height="20" Margin="0,0,8,0" />
                                <TextBlock Text="បញ្ជីផ្នែក" FontSize="18" FontWeight="Bold" />
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding Departments}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="14"
                                      FontFamily="{StaticResource NotoSansKhmer}"
                                      MaxHeight="400">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="ឈ្មោះខ្មែរ" Binding="{Binding KhmerName}" Width="200" />
                                    <DataGridTextColumn Header="ឈ្មោះ (អង់គ្លេស)" Binding="{Binding Name}" Width="200" />
                                    <DataGridTextColumn Header="ការពណ៌នា" Binding="{Binding Description}" Width="*" />
                                    <DataGridTemplateColumn Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Command="{Binding DataContext.EditDepartmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="8,3" Margin="2" FontSize="12"
                                                            Background="#FF9800" Foreground="White">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Edit" Width="14" Height="14" Margin="0,0,3,0" />
                                                            <TextBlock Text="កែប្រែ" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteDepartmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="8,3" Margin="2" FontSize="12"
                                                            Background="#F44336" Foreground="White">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Margin="0,0,3,0" />
                                                            <TextBlock Text="លុប" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Department form -->
                            <Border Background="#F5F5F5" CornerRadius="4" Padding="15" Margin="0,10,0,0"
                                    Visibility="{Binding ShowDepartmentForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel TextElement.Foreground="Black">
                                    <TextBlock Text="{Binding DepartmentFormTitle}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="ឈ្មោះ (អង់គ្លេស)" FontSize="16" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding DepartmentName, UpdateSourceTrigger=PropertyChanged}" 
                                                     Padding="6" FontSize="16" FontFamily="{StaticResource NotoSansKhmer}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5">
                                            <TextBlock Text="ឈ្មោះខ្មែរ" FontSize="16" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding DepartmentKhmerName, UpdateSourceTrigger=PropertyChanged}" 
                                                     Padding="6" FontSize="16" FontFamily="{StaticResource NotoSansKhmer}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="5">
                                            <TextBlock Text="ការពណ៌នា" FontSize="16" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding DepartmentDescription, UpdateSourceTrigger=PropertyChanged}" Padding="6" FontSize="16"
                                                     FontFamily="{StaticResource NotoSansKhmer}"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Command="{Binding CancelDepartmentFormCommand}"
                                                Padding="12,6" Margin="5" FontSize="16" Background="#9E9E9E" Foreground="White">
                                            <TextBlock Text="បោះបង់" />
                                        </Button>
                                        <Button Command="{Binding SaveDepartmentCommand}"
                                                Padding="12,6" Margin="5" FontSize="16" Background="#4CAF50" Foreground="White">
                                            <TextBlock Text="រក្សាទុក" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Loading overlay -->
            <Grid Background="#44000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="12" CornerRadius="8">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="20" />
                        <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
