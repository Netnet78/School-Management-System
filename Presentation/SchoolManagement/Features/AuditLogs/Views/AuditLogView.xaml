<UserControl x:Class="SchoolManagement.Presentation.Features.AuditLogs.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.AuditLogs.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:AuditLogViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
        <conv:UTCToLocalTimeConverter x:Key="UTCToLocalTimeConverter" />
    </UserControl.Resources>

    <Grid Background="White" TextElement.FontFamily="{StaticResource NotoSansKhmer}" TextElement.FontSize="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <TextBlock Text="ប្រវត្តិប្រតិបត្តិការ" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,0,0">
                <Button Command="{Binding RefreshCommand}"
                        Padding="10,5"
                        Margin="5"
                        Background="#2196F3"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,5,0" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ResetFiltersCommand}"
                        Padding="10,5"
                        Margin="5"
                        Background="#FF9800"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Broom"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,5,0" />
                        <TextBlock Text="សម្អាតការច្រោះទិន្នន័យ" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <Expander Grid.Row="1" Margin="20,10" Background="#F5F5F5" Padding="10" IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Filter" VerticalAlignment="Center" Margin="0 0 5 0" />
                    <TextBlock FontSize="18" FontWeight="Bold">ច្រោះទិន្នន័យ</TextBlock>
                </StackPanel>
            </Expander.Header>

            <StackPanel>
                <Grid ColumnDefinitions="*,*,*" TextElement.FontFamily="{StaticResource NotoSansKhmer}" TextElement.FontSize="16">
                    <StackPanel Margin="5">
                        <TextBlock Text="ស្វែងរកតាមប្រភេទ/សកម្មភាព/អ្នកប្រើប្រាស់"
                                   FontWeight="Regular"
                                   FontSize="16"
                                   Margin="0,0,0,5" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="8" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="ចាប់ពីថ្ងៃ" FontWeight="Regular" FontSize="16" Margin="0,0,0,5" />
                        <DatePicker SelectedDate="{Binding FromDate}" Padding="8" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="ដល់ថ្ងៃ" FontWeight="Regular" FontSize="16" Margin="0,0,0,5" />
                        <DatePicker SelectedDate="{Binding ToDate}" Padding="8" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Expander>

        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <DataGrid ItemsSource="{Binding AuditLogs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontFamily="{StaticResource NotoSansKhmer}"
                              FontSize="16"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowDetailsVisibilityMode="VisibleWhenSelected">
                        <DataGrid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="16" />
                            </Style>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="Height" Value="48" />
                                <Setter Property="BorderThickness" Value=".5" />
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" />
                            <DataGridTextColumn Header="ប្រភេទ" Binding="{Binding EntityType}" Width="120" />
                            <DataGridTextColumn Header="ឈ្មោះ" Binding="{Binding EntityName}" Width="140" />
                            <DataGridTextColumn Header="សកម្មភាព" Binding="{Binding Action}" Width="180" />
                            <DataGridTextColumn Header="អ្នកប្រើប្រាស់" Binding="{Binding User.Username}" Width="130" />
                            <DataGridTextColumn Header="កាលបរិច្ឆេទ" 
                                                Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, 
                                                Converter={StaticResource UTCToLocalTimeConverter}}" 
                                                Width="160" />
                        </DataGrid.Columns>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Padding="15" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,5" />
                                        <TextBlock Visibility="{Binding OldValues, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=NotNull}">
                                            <Run FontWeight="Bold" Text="តម្លៃចាស់: " />
                                            <Run Text="{Binding OldValues}" />
                                        </TextBlock>
                                        <TextBlock Visibility="{Binding NewValues, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=NotNull}">
                                            <Run FontWeight="Bold" Text="តម្លៃថ្មី: " />
                                            <Run Text="{Binding NewValues}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>

                    <Grid Background="#44000000"
                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="White"
                                Padding="12"
                                CornerRadius="8">
                            <StackPanel>
                                <ProgressBar IsIndeterminate="True" Width="200" Height="20" />
                                <TextBlock Text="កំពុងផ្ទុកប្រវត្តិប្រតិបត្តិការ..."
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"
                                           FontSize="16" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentPage, StringFormat=ទំព័រ {0}}"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Margin="0,0,10,0" />
                <Button Content="ទៅក្រោយ"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding HasPreviousPage}"
                        Padding="12,6"
                        Margin="15,0,8,0"
                        FontSize="16" />
                <Button Content="ទៅមុខ"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding HasNextPage}"
                        Padding="12,6"
                        FontSize="16" />
            </StackPanel>
        </Grid> 
    </Grid>
</UserControl>
