<UserControl x:Class="SchoolManagement.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             
             xmlns:local="clr-namespace:SchoolManagement.Presentation.Views"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"             
             d:DataContext="{d:DesignInstance Type=viewmodels:DashboardViewModel}"
             mc:Ignorable="d"
             
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             
             Background="{DynamicResource MaterialDesignPaper}"
             d:DesignHeight="1000" d:DesignWidth="1400">

    <UserControl.Resources>
        <conv:CountToVisiblityConverter x:Key="CountToVisiblityConverter"/>
        <conv:CountToVisiblityConverter x:Key="CountToVisiblityConverterReversed" IsReversed="True"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" Collapse="True" IsReversed="True"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl Margin="20" VirtualizingPanel.IsVirtualizing="True">

            <!-- HEADER -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="ផ្ទាំងគ្រប់គ្រង"
                       FontSize="26"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
                
                <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ច្រោះចាប់ពី" VerticalAlignment="Center" Margin="10 0" FontSize="16"/>
                        <ComboBox SelectedItem="{Binding FromYear, Mode=TwoWay, FallbackValue=2023}"
                              ItemsSource="{Binding YearList}"
                              Width="150"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="រហូតដល់ឆ្នាំ" VerticalAlignment="Center" Margin="10 0" FontSize="16"/>
                        <ComboBox SelectedItem="{Binding ToYear, Mode=TwoWay, FallbackValue=2026}"
                              ItemsSource="{Binding YearList}"
                              Width="150"/>
                    </StackPanel>

                    <Button Margin="10 0 0 0" Command="{Binding RefreshDataCommand}">
                        <materialDesign:PackIcon Kind="ArrowRight" />
                    </Button>
                </WrapPanel>
            </Grid>

            <!-- ===================== -->
            <!-- SUMMARY CARDS -->
            <!-- ===================== -->
            <ScrollViewer>
                <UniformGrid Columns="4" Margin="0,0,0,20">

                    <Border CornerRadius="12" Padding="20" Margin="5" Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                        <StackPanel>
                            <TextBlock Text="ចំនួនសិស្សសរុប" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" FontSize="16" Margin="0 0 0 10"/>
                            <TextBlock Text="{Binding TotalStudents, StringFormat=0 នាក់}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="12" Padding="20" Margin="5" Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                        <StackPanel>
                            <TextBlock Text="ថ្នាក់រៀនសរុប" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" FontSize="16" Margin="0 0 0 10"/>
                            <TextBlock Text="{Binding TotalClasses, StringFormat=0 បន្ទប់}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="12" Padding="20" Margin="5" Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                        <StackPanel>
                            <TextBlock Text="ចំនួនគ្រូបង្រៀន" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" FontSize="16" Margin="0 0 0 10"/>
                            <TextBlock Text="{Binding TotalTeachers, StringFormat=0 នាក់}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="12" Padding="20" Margin="5" Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                        <StackPanel>
                            <TextBlock Text="ចំនួនសិស្សស្នាក់ក្នុង" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" FontSize="16" Margin="0 0 0 10"/>
                            <TextBlock Text="{Binding TotalStayInStudents, StringFormat=0 នាក់}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </ScrollViewer>

            <!-- ===================== -->
            <!-- MAIN CHART -->
            <!-- ===================== -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="ចំនួនសិស្សក្នុងមួយថ្នាក់រៀន"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <lvc:CartesianChart Series="{Binding StudentsPerClassChart.Series}"
                                        XAxes="{Binding StudentsPerClassChart.XAxes}"
                                        YAxes="{Binding StudentsPerClassChart.YAxes}" 
                                        Visibility="{Binding StudentsPerClassChart.IsEmpty,
                                            Converter={StaticResource BooleanToVisibilityConverterReversed}}"/>

                    <StackPanel Visibility="{Binding StudentsPerClassChart.IsEmpty, 
                            Converter={StaticResource BooleanToVisibilityConverter}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Opacity=".6">
                        <materialDesign:PackIcon Kind="AccountOff" Width="64" Height="64"  HorizontalAlignment="Center" Margin="0 20 0 25"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="16">គ្មានទិន្នន័យសិស្សដែលមានថ្នាក់រៀនក្នុងមូលដ្ឋានទិន្នន័យទេ!</TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===================== -->
            <!-- BOTTOM SECTION -->
            <!-- ===================== -->
            <UniformGrid Columns="3">

                <!-- Gender Chart -->
                <Border Margin="0 0 5 0" Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ចំនួនភេទនៃសិស្ស"
                                   Margin="0,0,0,10"
                                   FontSize="16"/>

                        <Rectangle Margin="0,0,0,10" Fill="{DynamicResource MaterialDesign.Brush.Foreground}" Height="1"/>

                        <StackPanel Visibility="{Binding GenderChart.IsEmpty, 
                                        Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                            <lvc:PieChart Series="{Binding GenderChart.Series}" Height="200" />
                            <StackPanel Orientation="Horizontal" Margin="0 10">
                                <Ellipse Width="16" Height="16" Fill="#0082C9"/>
                                <TextBlock Margin="10 0 0 0" Text="{Binding MaleCount}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Fill="#FF85C1"/>
                                <TextBlock Margin="10 0 0 0" Text="{Binding FemaleCount}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding GenderChart.IsEmpty, 
                            Converter={StaticResource BooleanToVisibilityConverter}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Opacity=".6">
                            <materialDesign:PackIcon Kind="AccountOff" Width="64" Height="64"  HorizontalAlignment="Center" Margin="0 20 0 25"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="16">គ្មានទិន្នន័យភេទនៃសិស្សទេ</TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Attendance Chart -->
                <Border Margin="0 0 5 0" Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ភាគរយនៃវត្តមានសិស្ស (ក្នុងថ្ងៃនេះ)"
                                   Margin="0,0,0,10"
                                   FontSize="16"/>

                        <Rectangle Margin="0,0,0,10" Fill="{DynamicResource MaterialDesign.Brush.Foreground}" Height="1"/>

                        <StackPanel Visibility="{Binding AttendanceChart.IsEmpty,
                                        Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                             <lvc:PieChart Series="{Binding AttendanceChart.Series}" Height="200" />
                            <StackPanel Orientation="Horizontal" Margin="0 10">
                                <Ellipse Width="16" Height="16" Fill="#FFB52C"/>
                                <TextBlock Margin="10 0 0 0" Text="{Binding LateCount}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Fill="#F03A17"/>
                                <TextBlock Margin="10 0 0 0" Text="{Binding AbsentCount}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Fill="#F155E2" Margin="0 10"/>
                                <TextBlock Margin="10 0 0 0" Text="{Binding ExcusedCount}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Fill="#07DF03"/>
                                <TextBlock Margin="10 0 0 0" Text="{Binding PresentCount}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding AttendanceChart.IsEmpty, 
                            Converter={StaticResource BooleanToVisibilityConverter}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Opacity=".6">
                            <materialDesign:PackIcon Kind="AccountOff" Width="64" Height="64"  HorizontalAlignment="Center" Margin="0 20 0 25"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="16">គ្មានទិន្នន័យវត្តមានសិស្សថ្មីៗ ក្នុងអំឡុងពេលនេះទេ!</TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Recent Students -->
                <Border Margin="0 0 0 0" Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="សិស្សដែលបានបន្ថែមថ្មី"
                                   Margin="0,0,0,10"
                                   FontSize="16"/>
                        
                        <Rectangle Margin="0,0,0,10" Fill="{DynamicResource MaterialDesign.Brush.Foreground}" Height="1"/>

                        <ListBox ItemsSource="{Binding RecentStudents}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Visibility="{Binding RecentStudents, Converter={StaticResource CountToVisiblityConverter}, FallbackValue=Collapsed}">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5">
                                        <TextBlock Text="{Binding FullName}" 
                                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"/>

                                        <TextBlock Text="{Binding CreatedDate}"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" FontSize="16"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                        <StackPanel Visibility="{Binding RecentStudents, Converter={StaticResource CountToVisiblityConverterReversed}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Opacity=".6">
                            <materialDesign:PackIcon Kind="AccountOff" Width="64" Height="64"  HorizontalAlignment="Center" Margin="0 20 0 25"/>
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="16">គ្មានទិន្នន័យសិស្សថ្មីៗ ក្នុងអំឡុងពេលដែលបានច្រោះទេ!</TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </ItemsControl>
    </ScrollViewer>
</UserControl>