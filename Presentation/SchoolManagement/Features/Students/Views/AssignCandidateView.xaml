<UserControl x:Class="SchoolManagement.Presentation.Features.Students.Views.AssignCandidateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SchoolManagement.Presentation.Features.Students.Views" 
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Students.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:enum="clr-namespace:SchoolManagement.Core.Shared.Enums;assembly=SchoolManagement.Core"
             d:DataContext="{d:DesignInstance Type=viewmodels:AssignCandidateViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource MaterialDesign.Brush.Background}"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" CollapseWhenNull="True" />
        <conv:NullToBooleanConverter x:Key="NullToBooleanConverter" FalseOnNull="True" />
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:ValidPathToVisibilityConverter x:Key="ValidPathToVisiblity" />
        <conv:ValidPathToVisibilityConverter x:Key="ValidPathToVisiblityReversed" Reversed="True"/>

        <Storyboard x:Key="LoadingRotate" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoadingIndicator" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadingRotate}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Main Content (Left) -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Background="{DynamicResource MaterialDesign.Brush.Primary}" Height="60" TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Button Margin="0 0 5 0" Command="{Binding GoBackCommand}" Background="Transparent">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" VerticalAlignment="Center" />
                    </Button>
                    <materialDesign:PackIcon Kind="TicketUser" VerticalAlignment="Center" Height="28" Width="28" />
                    <TextBlock Text="ច្រោះយកបេក្ខជន" FontSize="22" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Command="{Binding AssignSelectedCandidateCommand}"
                            IsEnabled="{Binding SelectedCandidate, Converter={StaticResource NullToBooleanConverter}}"
                            Background="#4CAF50" BorderBrush="#388E3C">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountArrowRight" Width="20" Height="20" Margin="0,0,5,0"/>
                            <TextBlock Text="ដាក់ងារជាសិស្ស" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" Margin="0,0,5,0"/>
                            <TextBlock Text="ធ្វើបច្ចុប្បន្នភាព" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Data state filter and search -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center">ស្ថានភាពព័ត៌មាន៖</TextBlock>
                        <ComboBox Width="160" Height="32"
                                  SelectedValue="{Binding DataStateFilter, Mode=TwoWay}"
                                  DisplayMemberPath="Description"
                                  SelectedValuePath="Value"
                                  ItemsSource="{Binding DataStateFilterItems}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center">ស្វែងរក៖</TextBlock>
                        <TextBox Width="200" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Foreground="Gray" Margin="5,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Filters -->
                <Expander Grid.Row="1" Margin="0,5" Background="#F5F5F5" Padding="10">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Filter" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock FontSize="16" FontWeight="Bold">ច្រោះទិន្នន័យបន្ថែម</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>
                        <Grid ColumnDefinitions="*,*,*,*" TextElement.FontSize="14">
                            <StackPanel Margin="5">
                                <TextBlock Text="ភេទ" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding SelectedGender}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="ទាំងអស់" Tag="{x:Null}"/>
                                    <ComboBoxItem Content="ប្រុស" Tag="{x:Static enum:Gender.Male}"/>
                                    <ComboBoxItem Content="ស្រី" Tag="{x:Static enum:Gender.Female}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="ថ្ងៃចាប់ផ្ដើម" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding FromDate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="5">
                                <TextBlock Text="ថ្ងៃបញ្ចប់" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding ToDate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="5">
                                <TextBlock Text="តម្រៀបតាម" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding SortBy}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="ID" Tag="Id"/>
                                    <ComboBoxItem Content="ឈ្មោះ" Tag="FullName"/>
                                    <ComboBoxItem Content="កាលបរិច្ឆេទ" Tag="CreatedAt"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="5,10,0,5">
                            <Button Command="{Binding RefreshCommand}" Background="#2196F3" Foreground="White" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Filter" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="អនុវត្តការច្រោះ" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ClearFiltersCommand}" Margin="10,0,0,0" Background="#FF9800" Foreground="White" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Broom" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="សម្អាត" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- DataGrid -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}" BorderThickness="1" Margin="0,5">
                    <Grid>
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding CandidatesView}"
                                  SelectionMode="Single"
                                  SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                  Visibility="{Binding DataLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell" x:Key="GridCellStyle">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}"/>
                                    <Setter Property="Foreground" Value="Black" />
                                </Style>
                                <Style TargetType="TextBlock" x:Key="CellTextBlock">
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="14" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.CellStyle>
                                <StaticResource ResourceKey="GridCellStyle" />
                            </DataGrid.CellStyle>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                                    <Setter Property="Padding" Value="5" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="លេខសម្គាល់" Binding="{Binding Id, StringFormat=DBS{0:000}}" Width="100" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="គោត្តនាម និងនាម" Binding="{Binding FullName}" Width="200" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="ភេទ" Binding="{Binding Gender, Converter={StaticResource EnumToDescriptionConverter}}" Width="70" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="ថ្ងៃខែឆ្នាំកំណើត" Binding="{Binding DateOfBirth}" Width="120" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="អាយុ" Binding="{Binding Age, StringFormat=' {0} ឆ្នាំ'}" Width="70" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="ជំនាញ" Binding="{Binding Skill.KhmerName}" Width="120" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="សាសនា" Binding="{Binding Religion}" Width="100" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="លេខទូរស័ព្ទ" Binding="{Binding PhoneNumber}" Width="130" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="ឈ្មោះសាលារៀន" Binding="{Binding FromSchool}" Width="180" ElementStyle="{StaticResource CellTextBlock}" />
                                <DataGridTextColumn Header="មណ្ឌលប្រឡង" Binding="{Binding ExamCenter}" Width="130" ElementStyle="{StaticResource CellTextBlock}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Loading overlay -->
                        <Border Background="White" Opacity="0.7"
                                Visibility="{Binding DataLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Loading" Width="48" Height="48" 
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                <TextBlock Text="កំពុងផ្ទុកទិន្នន័យ..." FontSize="18" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Pagination -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Right">
                    <Button ToolTip="រំលងថយក្រោយ 5 ទំព័រ" CommandParameter="-5" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronDoubleLeft" />
                    </Button>
                    <Button Margin="5,0" ToolTip="រំលងថយក្រោយ 1 ទំព័រ" CommandParameter="-1" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronLeft" />
                    </Button>
                    <TextBlock Text="ទំព័រទី" VerticalAlignment="Center" Margin="5,0" />
                    <TextBox Width="48" FontSize="14" Text="{Binding CurrentPage, Mode=TwoWay}" TextAlignment="Center" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" />
                    <TextBlock Text="នៃ" VerticalAlignment="Center" Margin="5,0" />
                    <Border Width="48" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}" Margin="0,0,5,0">
                        <TextBlock Text="{Binding MaximumPages}" TextAlignment="Center" Margin="0,2" VerticalAlignment="Center"/>
                    </Border>
                    <Button ToolTip="រំលងទៅមុខ 1 ទំព័រ" CommandParameter="1" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronRight" />
                    </Button>
                    <Button Margin="5,0" ToolTip="រំលងទៅមុខ 5 ទំព័រ" CommandParameter="5" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronDoubleRight" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Selected Candidate Info Card (Right) -->
        <Border Grid.Column="1"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                BorderThickness="2"
                CornerRadius="10"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Margin="0,10,10,10"
                Width="280"
                Visibility="{Binding SelectedCandidate, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Photo and Name -->
                <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Stretch">
                    <Border Margin="0,15,0,0" BorderThickness="4" Width="128" BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}" HorizontalAlignment="Center">
                        <Grid Width="128" Height="154">
                            <materialDesign:PackIcon Kind="Loading"
                                                     x:Name="LoadingIndicator"
                                                     Width="48" Height="48"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     RenderTransformOrigin="0.5,0.5"
                                                     Visibility="{Binding IsLoadingPhoto, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                                                     Panel.ZIndex="1">
                                <materialDesign:PackIcon.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </materialDesign:PackIcon.RenderTransform>
                            </materialDesign:PackIcon>

                            <Viewbox Visibility="{Binding ValidPhotoPath, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                                     StretchDirection="DownOnly" Stretch="UniformToFill">
                                <Image Stretch="Uniform"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="{Binding SelectedCandidatePhoto.FilePath, Converter={StaticResource PhotoPathToImageSourceConverter}}" />
                            </Viewbox>

                            <Border Visibility="{Binding ValidPhotoPath, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Visible}"
                                    Background="Transparent">
                                <materialDesign:PackIcon Kind="UserQuestion"
                                                         Width="48" Height="48"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding IsLoadingPhoto, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Visible}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock HorizontalAlignment="Center"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,10,0,5"
                               Text="{Binding SelectedCandidate.FullName, FallbackValue='ឈ្មោះ'}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="14"
                               Text="{Binding SelectedCandidate.Id, StringFormat=DBS{0:000}}" />
                </StackPanel>

                <!-- Full Information -->
                <Border Grid.Row="1" Padding="10" BorderBrush="Transparent" BorderThickness="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="ព័ត៌មានផ្ទាល់ខ្លួន" FontWeight="Bold" FontSize="14" Margin="0,8,0,4" />
                            <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0,0,0,3" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="ភេទ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.Gender, Converter={StaticResource EnumToDescriptionConverter}}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ថ្ងៃខែឆ្នាំកំណើត:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.DateOfBirth, StringFormat=' {0:dd}/{0:MM}/{0:yyyy}'}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="អាយុ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.Age, StringFormat=' {0:00} ឆ្នាំ'}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ជំនាញ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.Skill.KhmerName}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="សាសនា:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.Religion}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ចំនួនបងប្អូន:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.SiblingsCount, StringFormat=' {0:00} នាក់'}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="លេខទូរស័ព្ទ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.PhoneNumber}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>

                            <TextBlock Text="ទីកន្លែងកំណើត" FontWeight="Bold" FontSize="14" Margin="0,8,0,4" />
                            <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0,0,0,3" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="ភូមិ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.BirthVillage}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ឃុំ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.BirthCommune}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ស្រុក:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.BirthDistrict}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ខេត្ត:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.BirthProvince}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>

                            <TextBlock Text="ឪពុក និង ម្តាយ" FontWeight="Bold" FontSize="14" Margin="0,8,0,4" />
                            <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0,0,0,3" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="ឈ្មោះឪពុក:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.FatherName}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="មុខរបរឪពុក:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.FatherOccupation}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="ឈ្មោះម្ដាយ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.MotherName}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="មុខរបរម្ដាយ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.MotherOccupation}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>

                            <TextBlock Text="ព័ត៌មានប្រឡង" FontWeight="Bold" FontSize="14" Margin="0,8,0,4" />
                            <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0,0,0,3" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="មណ្ឌលប្រឡង:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.ExamCenter}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="កាលបរិច្ឆេទ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.ExamDate, StringFormat=' {0:dd}/{0:MM}/{0:yyyy}'}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="លេខតុ:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.ExamTable}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="លេខបន្ទប់:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.ExamRoom}" Margin="10,0,0,0" FontSize="13" />
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="មកពីសាលារៀន:" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.FromSchool}" TextWrapping="Wrap" Margin="10,4,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="ការស្នាក់នៅ:" FontStyle="Italic" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.StayType, Converter={StaticResource EnumToDescriptionConverter}}" TextWrapping="Wrap" Margin="10,4,0,0" FontSize="13" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="ផ្សេងៗ:" FontStyle="Italic" FontSize="13" />
                                <TextBlock Text="{Binding SelectedCandidate.OtherInfo}" TextWrapping="Wrap" Margin="10,4,0,0" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
