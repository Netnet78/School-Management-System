<UserControl x:Class="SchoolManagement.Presentation.Features.Students.Views.AssignStudentClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Students.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance Type=viewmodels:AssignStudentClassViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
        <conv:BooleanInverseConverter x:Key="BooleanInverseConverter" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
            </Button>
            <StackPanel>
                <TextBlock Text="ទម្រង់ចាត់តាំងថ្នាក់សិស្ស" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding StudentName, StringFormat='សិស្ស: {0}'}" FontSize="14" Foreground="#666" Margin="0,4,0,0" />
                <TextBlock Text="សូមធ្វើការជ្រើសរើសនូវថ្នាក់ណាមួយ ឬក៏បោះបង់ដើម្បីបន្តទៅមុខមិនបាច់ដាក់ថ្នាក់" FontSize="14" Foreground="#666" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="220" Height="20" Margin="0,0,0,10" />
                    <TextBlock Text="Loading classes..." HorizontalAlignment="Center" FontSize="16" />
                </StackPanel>
            </Grid>

            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox IsChecked="{Binding ShowInactiveClasses, UpdateSourceTrigger=PropertyChanged}"
                              VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Show inactive classes" FontSize="14" VerticalAlignment="Center" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <ItemsControl ItemsSource="{Binding AvailableClasses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Class.KhmerName}" FontSize="15" FontWeight="SemiBold" />
                                            <StackPanel Orientation="Horizontal" TextElement.FontSize="13" TextElement.Foreground="#666">
                                                <TextBlock Text="{Binding Class.Grade.KhmerName, StringFormat='Grade: {0}'}" Margin="0,0,15,0" />
                                                <TextBlock Text="{Binding Class.Generation.Department.KhmerName, StringFormat='Dept: {0}'}" Margin="0,0,15,0" />
                                                <TextBlock Text="{Binding Class.Teacher.FullName, StringFormat='Teacher: {0}'}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding CanAssignClass, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                <TextBlock Text="មិនអនុញ្ញាត​ឱ្យ​ចូលប្រើប្រាស់" FontSize="20" FontWeight="Bold" Foreground="Red" Margin="0,0,0,10" />
                <TextBlock Text="អ្នកគ្មានសិទ្ធិគ្រប់គ្រាន់ក្នុងការកំណត់ថ្នាក់ឱ្យសិស្សទេ!" FontSize="14" TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Background="{DynamicResource MaterialDesign.Brush.Primary}" />
                <TextBlock Text="កំពុងរក្សាទុក..." HorizontalAlignment="Center" FontSize="14" Margin="0,5,0,0" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
            <Button Command="{Binding CancelCommand}" Padding="15,8" Margin="5" FontSize="14" Background="Red" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,5,0" />
                    <TextBlock Text="បោះបង់" />
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" Padding="15,8" Margin="5" FontSize="14" Background="#4CAF50" Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,5,0" />
                    <TextBlock Text="រក្សាទុក" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
