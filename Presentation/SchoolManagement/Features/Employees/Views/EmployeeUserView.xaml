<UserControl x:Class="SchoolManagement.Presentation.Features.Employees.Views.EmployeeUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             xmlns:viewmodels="clr-namespace:SchoolManagement.Presentation.Features.Employees.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance Type=viewmodels:EmployeeUserViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" Collapse="True" IsReversed="True" />
    </UserControl.Resources>

    <Grid Background="White" TextElement.FontFamily="{StaticResource NotoSansKhmer}" TextElement.FontSize="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20" VerticalAlignment="Center">
            <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" />
            </Button>
            <StackPanel>
                <TextBlock Text="គ្រប់គ្រងគណនីអ្នកប្រើប្រាស់" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding EmployeeName, StringFormat='បុគ្គលិក: {0}'}" 
                           FontSize="16" Opacity=".7" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0,20,20">
            <StackPanel>
                <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                        Padding="15" Margin="20,20" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="Account" Width="20" Height="20"
                                                      Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                                                      Margin="0,0,8,0" />
                            <TextBlock Text="ព័ត៌មានគណនី" FontSize="18" FontWeight="Bold" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <StackPanel Margin="5">
                                <TextBlock Text="ស្ថានភាពគណនី" Margin="0,0,0,4" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UserStatusText}" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="តួនាទី" Margin="0,0,0,4" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UserRoleName}" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="5">
                                <TextBlock Text="ការចូលចុងក្រោយ" Margin="0,0,0,4" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LastLoginText}" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                <TextBlock Text="ស្ថានភាពចាក់សោ" Margin="0,0,0,4" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding IsLockedOut}" Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Padding="15" Margin="20,20" CornerRadius="4"
                        Visibility="{Binding HasUserAccount, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="AccountPlus" Width="20" Height="20"
                                                      Margin="0,0,8,0" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="បង្កើតគណនីអ្នកប្រើប្រាស់" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                            <StackPanel Margin="5">
                                <TextBlock Text="ឈ្មោះអ្នកប្រើ" Margin="0,0,0,4" />
                                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="តួនាទី" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Roles}"
                                          SelectedValue="{Binding SelectedRoleId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="5">
                                <TextBlock Text="ពាក្យសម្ងាត់" Margin="0,0,0,4" />
                                <PasswordBox x:Name="NewPasswordBox" Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                <TextBlock Text="បញ្ជាក់ពាក្យសម្ងាត់" Margin="0,0,0,4" />
                                <PasswordBox x:Name="ConfirmPasswordBox" Padding="8" />
                            </StackPanel>
                        </Grid>

                        <Button Command="{Binding CreateUserCommand}"
                                Padding="12,8"
                                Margin="5,10,5,0"
                                Background="#4CAF50"
                                Foreground="White"
                                HorizontalAlignment="Left"
                                IsEnabled="{Binding CanManageUsers}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,5,0" />
                                <TextBlock Text="បង្កើតគណនី" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Padding="15" Margin="20,20" CornerRadius="4"
                        Visibility="{Binding HasUserAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="AccountSettings" Width="20" Height="20"
                                                      Margin="0,0,8,0" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="កែប្រែគណនីអ្នកប្រើប្រាស់" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        </StackPanel>

                        <Border Background="#F5F5F5" Padding="12" Margin="0,8" CornerRadius="4">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="ផ្លាស់ប្តូរតួនាទី:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Roles}"
                                          SelectedValue="{Binding SelectedRoleId}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          Padding="8"
                                          Width="200"
                                          HorizontalAlignment="Left" />
                                <Button Grid.Column="2"
                                        Command="{Binding SaveRoleCommand}"
                                        Padding="10,6"
                                        Margin="10,0,0,0"
                                        Background="#2196F3"
                                        Foreground="White"
                                        IsEnabled="{Binding CanManageUsers}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,4,0" />
                                        <TextBlock Text="រក្សាទុក" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Background="#F5F5F5" Padding="12" Margin="0,8" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="កំណត់ពាក្យសម្ងាត់ថ្មី" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid ColumnDefinitions="*,*,Auto">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="ពាក្យសម្ងាត់ថ្មី" Margin="0,0,0,4" FontSize="14" />
                                        <PasswordBox x:Name="ResetPasswordBox" Padding="8" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="បញ្ជាក់ពាក្យសម្ងាត់" Margin="0,0,0,4" FontSize="14" />
                                        <PasswordBox x:Name="ResetConfirmPasswordBox" Padding="8" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding ResetPasswordCommand}"
                                            Padding="10,6"
                                            Margin="10,18,0,0"
                                            Background="#FF9800"
                                            Foreground="White"
                                            VerticalAlignment="Bottom"
                                            IsEnabled="{Binding CanManageUsers}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LockReset" Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="កំណត់ឡើងវិញ" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#F5F5F5" Padding="12" Margin="0,8" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="សកម្មភាព" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding ToggleActiveCommand}"
                                            Padding="10,6"
                                            Margin="0,0,8,0"
                                            Background="#9C27B0"
                                            Foreground="White"
                                            IsEnabled="{Binding CanManageUsers}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountTag" Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="បិទ/បើកគណនី" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding UnlockUserCommand}"
                                            Padding="10,6"
                                            Margin="0,0,8,0"
                                            Background="#607D8B"
                                            Foreground="White"
                                            IsEnabled="{Binding CanManageUsers}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LockOpen" Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="ដោះសោ" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DeleteUserCommand}"
                                            Padding="10,6"
                                            Background="#F44336"
                                            Foreground="White"
                                            IsEnabled="{Binding CanManageUsers}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="លុបគណនី" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20" Background="{DynamicResource MaterialDesign.Brush.Secondary}" />
                <TextBlock Text="កំពុងដំណើរការ..." HorizontalAlignment="Center" FontSize="16" Margin="0,5,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
