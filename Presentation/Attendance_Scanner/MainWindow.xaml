<Window x:Class="Attendance_Scanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:materialDesigns="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Attendance_Scanner.ViewModels"
        xmlns:components="clr-namespace:School_Management.Presentation.Shared.Components;assembly=School_Management.Presentation.Shared"
        xmlns:converters="clr-namespace:School_Management.Presentation.Shared.XAMLConverters;assembly=School_Management.Presentation.Shared"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="Attendance Scanner" Height="580" Width="1020"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="/Sources/Images/dbslogo_filled.png"
        MinWidth="1020"
        MinHeight="580"
        Closing="Window_Closing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:ValidPathToVisibility x:Key="ValidPathToVisibility" />
        <converters:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <converters:ValidPathToVisibility x:Key="ValidPathToVisibilityReversed" Reversed="True" />
        <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" Collapse="True" IsReversed="True" />
        <converters:BooleanInverseConverter x:Key="BooleanInverseConverter" />
        <converters:BitmapToBitmapSourceConverter x:Key="BitmapToBitmapSourceConverter" />
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" BorderThickness="8" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <!--For minimize, close and maximize buttons-->
                <RowDefinition Height="Auto" />
                <!--For navigation bar and main content-->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0" Replace="True" Title="សួស្ដីប្អូនៗ សូមស្វាគមន៍មកកាន់កម្មវិធីស្រង់អវត្តមាន!" />

            <!--Main content-->
            <Grid Background="White" Grid.Row="1" TextElement.Foreground="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0*" x:Name="MainContentFirstGridDefinition"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--Left Side Header-->
                <Border x:Name="LeftSideHeader"
                        Padding="10"
                        BorderBrush="White"
                        BorderThickness="0 0 0 2"
                        DockPanel.Dock="Top" Grid.Row="0"
                        Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}">
                        <materialDesigns:PackIcon Kind="UserCheck"
                                                  VerticalAlignment="Center"
                                                  Width="24" Height="24" Margin="0 0 10 0" />
                        <TextBlock Text="ព័ត៌មានសិស្សដែលបានស្កេន" FontSize="18" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 10 0" />
                    </StackPanel>
                </Border>
                <!--Left Side Content Container-->
                <Grid x:Name="LeftSideContentContainer" Background="{DynamicResource MaterialDesign.Brush.Secondary}" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--Left Section-->
                    <Viewbox Stretch="Uniform">
                        <Border Grid.Column="0" Padding="10" TextElement.FontSize="18">
                            <StackPanel>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="+ ឈ្មោះសិស្ស៖" Margin="0 0 7 5" />
                                    <TextBlock TextDecorations="Underline" Text="{Binding CurrentStudent.Candidate.FullName, FallbackValue=''}" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                    <TextBlock Text="+ ឈ្មោះសិស្សជាឡាតាំង៖" Margin="0 0 7 5" />
                                    <TextBlock TextDecorations="Underline" Text="{Binding CurrentStudent.Candidate.LatinFullName}" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                    <TextBlock Text="+ ភេទ៖" Margin="0 0 7 5" />
                                    <TextBlock TextDecorations="Underline" Text="{Binding CurrentStudent.Candidate.Gender, Converter={StaticResource EnumToDescriptionConverter}}" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                    <TextBlock Text="+ អាយុ៖" Margin="0 0 7 5" />
                                    <TextBlock TextDecorations="Underline" Text="{Binding CurrentStudent.Candidate.Age, StringFormat=0 ឆ្នាំ}" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                    <TextBlock Text="+ ជំនាញ៖" Margin="0 0 7 5" />
                                    <TextBlock TextDecorations="Underline" Text="{Binding CurrentStudent.Candidate.Skill.Name}" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Margin="0 10 0 0">
                                    <!--<TextBlock Text="+ កម្រិត៖" Margin="0 0 7 5" />
                    <TextBlock TextDecorations="Underline" Text="{Binding CurrentStudent}" />-->
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Viewbox>

                    <!--Right Section-->
                    <Viewbox Stretch="Uniform" Grid.Column="1" VerticalAlignment="Top">
                        <Border Padding="20 20 20 0">
                            <StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <!--<TextBlock Text="រូបថតសិស្សានុសិស្ស" HorizontalAlignment="Center" FontWeight="Bold" FontSize="18" />-->
                                    <Image Width="120" Height="180"
                                       Stretch="Uniform"
                                       Visibility="{Binding CurrentPhotoPath, Converter={StaticResource ValidPathToVisibility}, FallbackValue=Collapsed}"
                                       Source="{Binding CurrentPhotoPath, Converter={StaticResource PhotoPathToImageSourceConverter}}" />

                                    <Border Width="120" Height="180"
                                        Margin="0 5"
                                        BorderThickness="2"
                                        BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                                        Visibility="{Binding CurrentPhotoPath, Converter={StaticResource ValidPathToVisibilityReversed}}">
                                        <TextBlock Text="?"
                                           FontSize="72"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>

                                <StackPanel TextElement.FontSize="18" Orientation="Vertical" HorizontalAlignment="Center" Margin="0 0 0 0">
                                    <TextBlock Text="{Binding CurrentStudent.Candidate.FullName}" HorizontalAlignment="Center" />
                                    <TextBlock TextDecorations="Underline" HorizontalAlignment="Center" Text="{Binding CurrentStudent.Id, StringFormat=SDBS\{0:0000\}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Viewbox>
                </Grid>

                <!--Right Side Header-->
                <Border Padding="10"
                        Grid.Row="0" Grid.Column="1"
                        Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesigns:PackIcon Kind="Camera"
                                                  VerticalAlignment="Center"
                                                  Width="24" Height="24" Margin="0 0 10 0" />
                            <TextBlock Text="ឧបករណ៍កាមេរ៉ា" FontSize="18" VerticalAlignment="Center" FontWeight="Bold" />
                        </StackPanel>
                        <Border BorderBrush="White" BorderThickness="2" Margin="10 0 0 0" VerticalAlignment="Center">
                            <ComboBox Width="200" Padding="0 0 10 0"
                                      ItemsSource="{Binding AvailableDevices}"
                                      SelectedItem="{Binding SelectedDevice}"
                                      DisplayMemberPath="Name"
                                      x:Name="DeviceSelector"
                                      IsEnabled="{Binding IsLive, FallbackValue=True, Converter={StaticResource BooleanInverseConverter}}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!--Right Side Content Container-->
                <Grid Grid.Column="1" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Viewbox Stretch="Uniform">
                        <Grid>
                            <Border x:Name="VideoOutputContainer" Grid.Row="0" BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                                Width="1280" Height="720"
                                BorderThickness="5 0 5 5" Background="AliceBlue" Visibility="{Binding IsLive, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}">
                                <Grid>
                                    <Image x:Name="CameraOutput"
                                           Source="{Binding FrameSource}"
                                           SnapsToDevicePixels="True"
                                           Stretch="Uniform"
                                           RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="-1" />
                                        </Image.RenderTransform>
                                    </Image>

                                    <components:LoadingDialog DataContext="{Binding LoadingService}"
                                            LoadingText="{Binding Message}"
                                            ProgressValue="{Binding Progress}"
                                            State="{Binding State}"/>

                                    <!--Camera initialization loading panel-->
                                    <components:LoadingPanel IsLoading="{Binding IsCameraInitialized, Converter={StaticResource BooleanInverseConverter}}" />
                                    <Grid Background="{DynamicResource MaterialDesign.Brush.Primary}" Panel.ZIndex="-1"/>

                                </Grid>
                            </Border>

                            <Border Grid.Row="0" BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                                    Width="1280"
                                    Height="720"
                                    BorderThickness="5" Background="AliceBlue" Visibility="{Binding IsLive, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Collapsed}">
                                <materialDesigns:PackIcon
                                    Kind="VideoOff" Width="128" Height="128"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            </Border>
                        </Grid>
                    </Viewbox>

                    <StackPanel Orientation="Vertical"
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary}">
                        <TextBlock HorizontalAlignment="Center" Text="Scanner is Ready!" FontSize="24" FontWeight="Bold"
                                   Visibility="{Binding IsReady, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}" />
                        <TextBlock HorizontalAlignment="Center" Text="Scanner is Busy... Please wait..." FontSize="24" FontWeight="Bold"
                                   Visibility="{Binding IsReady, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Collapsed}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 0">
                            <StackPanel VerticalAlignment="Center">
                                <Button
                                Width="200"
                                Command="{Binding StopScanCommand}"
                                Visibility="{Binding IsLive, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="Indicator" Width="14" Height="14"
                                         Fill="Red" Margin="0 0 15 0"
                                         VerticalAlignment="Center" />
                                        <TextBlock x:Name="IndicatorText" Text="Scanning..." VerticalAlignment="Bottom" />
                                    </StackPanel>
                                </Button>
                                <Button
                                Width="200"
                                Command="{Binding StartScanCommand}"
                                Visibility="{Binding IsLive, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Visible}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="14" Height="14"
                                         Fill="Red" Margin="0 0 15 0"
                                         VerticalAlignment="Center" />
                                        <TextBlock Text="Start LIVE" VerticalAlignment="Bottom" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Button Margin="10 0 0 0"
                                    VerticalAlignment="Center"
                                    Command="{Binding RefreshValueCommand}">
                                <materialDesigns:PackIcon Kind="Refresh" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>