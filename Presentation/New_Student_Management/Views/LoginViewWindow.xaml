<Window x:Class="New_Student_Management.Views.LoginViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:New_Student_Management.Views"
        xmlns:helpers="clr-namespace:School_Management.Presentation.Shared.Helpers;assembly=School_Management.Presentation.Shared"
        xmlns:viewmodels="clr-namespace:New_Student_Management.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:School_Management.Presentation.Shared.Components;assembly=School_Management.Presentation.Shared"
        d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Login" Height="600" Width="850"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Accessible, larger typography for the login form -->
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0 0 0 6" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0 0 0 20" />
            <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
        </Style>

        <!-- Card-like container background -->
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF" />
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.15" />
        <Storyboard x:Key="FormAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="500">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BackEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="ImageAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PictureBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="360" />
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="360">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:01.8000000" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PictureBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0" />
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:01.8000000" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PictureBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0" />
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="00:00:01.8000000" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PictureBorder" Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0" />
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="0" />
                <EasingDoubleKeyFrame KeyTime="00:00:01.8000000" Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FormAnimation}" />
            <BeginStoryboard Storyboard="{StaticResource ImageAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="8" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" BorderThickness="8" Padding="0">
        <Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF1976D2" />
                <GradientStop Color="#FF002573" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <components:TitleBar Grid.Row="0" Replace="True" Title="Candidate Management App" />
            <Grid Margin="40" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left image scaled and constrained -->
                <Border x:Name="PictureBorder" Grid.Column="0"
        Margin="0 0 0 0"
        CornerRadius="1"
        BorderThickness="3"
        Width="360"
        Height="460" BorderBrush="White" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Image x:Name="image" Source="/Sources/Images/Computer_Students.jpg"
           Stretch="UniformToFill"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           SnapsToDevicePixels="True" />
                </Border>

                <!-- Right: card containing form -->
                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
                    <Border x:Name="border" Background="{StaticResource CardBackgroundBrush}"
            CornerRadius="8"
            Padding="28"
            Effect="{StaticResource CardShadow}">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Title -->
                            <TextBlock Grid.Row="0"
                               Text="សូមស្វាគមន៍មកកាន់កម្មវិធី គ្រប់គ្រងបេក្ខជន"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Style="{StaticResource TitleTextStyle}" />

                            <TextBlock Grid.Row="1"
                               Text="សូមធ្វើការបំពេញព័ត៌មានខាងក្រោមឱ្យបានត្រឹមត្រូវ"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 14" />

                            <!-- Form -->
                            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0 4 0 0">

                                <!-- Username -->
                                <StackPanel Orientation="Vertical" Margin="0 6 0 6">
                                    <TextBlock Text="Username" Style="{StaticResource LabelTextStyle}" />
                                    <TextBox x:Name="UsernameTextBox"
                                        Style="{StaticResource InputStyle}"
                                        Width="280"
                                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', FallbackValue='', Mode=TwoWay}"
                                        HorizontalAlignment="Left"
                                        VerticalContentAlignment="Center"
                                        AutomationProperties.Name="Username" />
                                </StackPanel>

                                <!-- Password -->
                                <StackPanel Orientation="Vertical" Margin="0 6 0 6">
                                    <TextBlock Text="Password" Style="{StaticResource LabelTextStyle}" />
                                    <PasswordBox Width="280"
                                        x:Name="PasswordBox"
                                        Style="{StaticResource InputStyle}"
                                        HorizontalAlignment="Left"
                                        VerticalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Action buttons -->
                            <Grid Grid.Row="3" HorizontalAlignment="Stretch" Margin="0 18 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="CancelButton"
                                    Width="120"
                                    Height="42"
                                    FontSize="16"
                                    IsCancel="True"
                                    Click="CancelButton_Click"
                                    Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Cancel" Margin="0 0 8 0" />
                                        <materialDesign:PackIcon Kind="CloseCircleOutline" Width="20" Height="20" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="LoginButton"
                                    Width="120"
                                    Height="42"
                                    FontSize="16"
                                    Command="{Binding LoginCommand}"
                                    CommandParameter="{Binding ElementName=PasswordBox, Path=SecurePassword}"
                                    IsDefault="True"
                                    Background="#FF1976D2"
                                    Foreground="White"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Login" Margin="0 0 8 0" />
                                        <materialDesign:PackIcon Kind="ArrowRightBoldCircleOutline" Width="20" Height="20" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Small footnote / version -->
                            <TextBlock Grid.Row="4"
                               Text="ប្រសិនបើមានបញ្ហាចូលគណនី សូមទាក់ទងទៅកាន់អ្នកគ្រប់គ្រង"
                               FontSize="12"
                               Foreground="#FF666666"
                               HorizontalAlignment="Center"
                               Margin="0 12 0 0" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>