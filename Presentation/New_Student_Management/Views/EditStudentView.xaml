<UserControl x:Class="New_Student_Management.Views.EditStudentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:School_Management.Presentation.Shared.XAMLConverters;assembly=School_Management.Presentation.Shared"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:viewmodels="clr-namespace:New_Student_Management.ViewModels" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:EditStudentViewModel}"
        Background="White">
    <UserControl.Resources>
        <conv:IntEqualsToVisibilityConverter x:Key="IntEqualsToVisibilityConverter" />
        <conv:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:ValidPathToVisibility x:Key="ValidPathToVisibility" Reversed="False" />
        <conv:ValidPathToVisibility x:Key="ValidPathToVisibilityReversed" Reversed="True"/>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4,2"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="{Binding EditedStudent.Id, StringFormat=' កែប្រែទិន្នន័យនៃ: DBS{0:000}', FallbackValue='កែប្រែទិន្នន័យរបស់: DBS000'}" FontSize="18" FontWeight="Bold" />
        </StackPanel>

        <!-- Content: three step panels -->
        <Grid Grid.Row="1" Margin="0,12,0,12" TextElement.FontSize="16" TextElement.FontFamily="{StaticResource NotoSansKhmer}">
            <!-- Step 0: Personal -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=0}">
                <TextBlock Text="Section: ព័ត៌មានផ្ទាល់ខ្លួន" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Width="320">
                        <TextBlock Text="គោត្តនាម" />
                        <TextBox Text="{Binding EditedStudent.LastName}"/>
                        <TextBlock Text="គោត្តនាមជាអក្សរឡាតាំង" />
                        <TextBox Text="{Binding EditedStudent.LatinLastName}"/>
                        <TextBlock Text="នាម" />
                        <TextBox Text="{Binding EditedStudent.FirstName}"/>
                        <TextBlock Text="នាមជាអក្សរឡាតាំង" />
                        <TextBox Text="{Binding EditedStudent.LatinFirstName}"/>

                        <TextBlock Text="ភេទ" />
                        <ComboBox SelectedValue="{Binding EditedStudent.Gender}" 
                                               IsEditable="False" 
                                               DisplayMemberPath="Description"
                                               SelectedValuePath="Value" 
                                               ItemsSource="{Binding GenderOptions}"/>

                        <TextBlock Text="កាលបរិច្ឆេទ​កំណើត" Margin="0 5 0 0"/>
                        <DatePicker Name="DateOfBirthPicker"
                                               SelectedDate="{Binding EditedStudent.DateOfBirth, FallbackValue='12/12/2012', Converter={StaticResource DateOnlyToDateTimeConverter}}" />
                    </StackPanel>

                    <StackPanel Width="320" Margin="20,0,0,0">
                        <TextBlock Text="ជំនាញ" />
                        <ComboBox  SelectedValue="{Binding EditedStudent.SkillId}"
                                                DisplayMemberPath="KhmerName"
                                                SelectedValuePath="Id"
                                                IsEditable="False"
                                                ItemsSource="{Binding SkillOptions}"/>

                        <TextBlock Text="សាសនា" />
                        <TextBox Text="{Binding EditedStudent.Religion}"/>

                        <TextBlock Text="ចំនួនបងប្អូន" />
                        <TextBox Text="{Binding EditedStudent.SiblingsCount}"/>

                        <TextBlock Text="លេខទូរស័ព្ទ" />
                        <TextBox Text="{Binding EditedStudent.PhoneNumber}"
                                         Height="25"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Step 1: Birth location -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=1}">
                <TextBlock Text="Section: ទីកន្លែងកំណើត" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Width="320">
                        <TextBlock Text="ភូមិ" />
                        <TextBox Text="{Binding EditedStudent.BirthVillage}"/>
                        <TextBlock Text="ឃុំ/សង្កាត់" />
                        <TextBox Text="{Binding EditedStudent.BirthCommune}"/>
                        <TextBlock Text="ស្រុក/ក្រុង" />
                        <TextBox Text="{Binding EditedStudent.BirthDistrict}"/>
                    </StackPanel>

                    <StackPanel Width="320" Margin="20,0,0,0">
                        <TextBlock Text="ខេត្ត" />
                        <TextBox Text="{Binding EditedStudent.BirthProvince}"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Step 2: Father / Mother info -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=2}">
                <TextBlock Text="Section: ឪពុក និង ម្ដាយ" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Width="320">
                        <TextBlock Text="ឈ្មោះម្ដាយ" />
                        <TextBox Text="{Binding EditedStudent.MotherName}"/>
                        <TextBlock Text="មុខរបរ" />
                        <TextBox Text="{Binding EditedStudent.MotherOccupation}"/>
                    </StackPanel>

                    <StackPanel Width="320" Margin="20,0,0,0">
                        <TextBlock Text="ឈ្មោះឪពុក" />
                        <TextBox Text="{Binding EditedStudent.FatherName}"/>
                        <TextBlock Text="មុខរបរ" />
                        <TextBox Text="{Binding EditedStudent.FatherOccupation}"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Step 3: Exam & Other -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=3}">
                <TextBlock Text="Section: ព័ត៌មានប្រឡង និង ផ្សេងៗ" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Width="320">
                        <TextBlock Text="មណ្ឌលប្រឡង" />
                        <TextBox Text="{Binding EditedStudent.ExamCenter}"/>
                        <TextBlock Text="កាលបរិច្ឆេទ" />
                        <DatePicker  SelectedDate="{Binding EditedStudent.ExamDate, Converter={StaticResource DateOnlyToDateTimeConverter}}"
                                                Name="ExamDatePicker"/>
                        <TextBlock Text="លេខតុ" />
                        <TextBox Text="{Binding EditedStudent.ExamTable}"/>
                        <TextBlock Text="លេខបន្ទប់" />
                        <TextBox Text="{Binding EditedStudent.ExamRoom}"/>
                    </StackPanel>

                    <StackPanel Width="320" Margin="20,0,0,0">
                        <TextBlock Text="មកពីសាលារៀន" />
                        <TextBox Text="{Binding EditedStudent.FromSchool}"/>
                        <TextBlock Text="ការស្នាក់នៅ" />
                        <ComboBox  ItemsSource="{Binding StayTypeOptions}"
                                                DisplayMemberPath="Description"
                                                SelectedValuePath="Value"
                                                SelectedValue="{Binding EditedStudent.StayType}" 
                                                IsEditable="False"/>
                        <TextBlock Text="ផ្សេងៗ" />
                        <TextBox Text="{Binding EditedStudent.OtherInfo}" AcceptsReturn="True" Height="100"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Step 4: Picture -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=4}">
                <TextBlock Text="Section: ព័ត៌មានរូបភាព" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel>
                    <Image Stretch="Uniform"
                               Width="200" Height="200"
                               Margin="0 0 0 20"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="{Binding CurrentPhoto.FilePath, Converter={StaticResource ValidPathToVisibility}, FallbackValue=Collapsed}"
                               Source="{Binding CurrentPhoto.FilePath, Converter={StaticResource PhotoPathToImageSourceConverter}}"/>
                    <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                                    BorderThickness="2"
                                    Width="160" Height="200"
                                    Visibility="{Binding CurrentPhoto.FilePath, Converter={StaticResource ValidPathToVisibilityReversed}, FallbackValue='Visible'}">
                        <TextBlock HorizontalAlignment="Center" 
                                            VerticalAlignment="Center" 
                                            FontSize="64" 
                                            Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                            Text="?"/>
                    </Border>
                    <Button Margin="0 10" Command="{Binding UploadPhotoCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Image" Margin="0 0 5 0"/>
                            <TextBlock>បង្ហោះរូបភាព</TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Footer: navigation -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Margin="4" Command="{Binding BackCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowBack" />
                    <TextBlock Text="Back" Margin="4,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Margin="4" Command="{Binding NextCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Next" Margin="0,0,4,0"/>
                    <materialDesign:PackIcon Kind="ArrowForward" />
                </StackPanel>  
            </Button>
            <Button Margin="4" Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Floppy" />
                    <TextBlock Text="Save" Margin="4,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Margin="4" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cancel" />
                    <TextBlock Text="Cancel" Margin="4,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
