<Window x:Class="New_Student_Management.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:New_Student_Management"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:School_Management.Presentation.Shared.XAMLConverters;assembly=School_Management.Presentation.Shared"
        xmlns:components="clr-namespace:School_Management.Presentation.Shared.Components;assembly=School_Management.Presentation.Shared"
        xmlns:viewModels="clr-namespace:New_Student_Management.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Candidates Management App" Height="850" Width="1250"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="Kantumruy Pro"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Icon="/Sources/Images/dbslogo_filled.png">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True"/>
        <Style x:Key="MenuBar" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}"/>
            <Setter Property="CornerRadius" Value="0 0 0 10" />
        </Style>
        <Storyboard x:Key="MenuBarAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource MenuBarAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    BorderBrush="Transparent"
                    CornerRadius="20"
                    Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0" Title="សាលាដុនបូស្កូ សាខាប៉ោយប៉ែត"/>

            <!--Main Content-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--Tab Menu-->
                <Border Grid.Column="0" Style="{DynamicResource MenuBar}">
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="20 10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!--School Name & Logo-->
                            <StackPanel 
                                TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                                Margin="0 10 0 20" HorizontalAlignment="Center">
                                <Image Width="128">
                                    <Image.Source>
                                        <BitmapImage DecodePixelWidth="128" UriSource="/Sources/Images/dbslogo_filled.png"/>
                                    </Image.Source>
                                </Image>
                                <TextBlock Margin="0 10 0 0"
                           Text="កម្មវិធីគ្រប់គ្រងបេក្ខជនចូលរៀន" 
                           FontSize="20" 
                           HorizontalAlignment="Center" FontWeight="Bold"
                           />
                                <StackPanel Margin="0 15 0 0" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock
                           Text="សូមស្វាគមន៍, " 
                           FontSize="18" 
                           HorizontalAlignment="Center"
                           />
                                    <TextBlock
                           Text="{Binding Username, FallbackValue='Username'}" 
                           FontSize="18" 
                           HorizontalAlignment="Center"
                           />
                                </StackPanel>
                            </StackPanel>

                            <!--Tab items-->
                            <StackPanel Grid.Row="1">
                                <Button Margin="0 0 0 20" Command="{Binding ShowTableViewCommand}">
                                    <Grid TextElement.FontSize="16" Width="231">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="Table" VerticalAlignment="Center" Width="20" Height="20"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0">Table View</TextBlock>
                                    </Grid>
                                </Button>

                                <Button Margin="0 0 0 20" Command="{Binding ShowInsertViewCommand}">
                                    <Grid TextElement.FontSize="16" Width="231">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="PlusBold" VerticalAlignment="Center" Width="20" Height="20"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0">Insert Student</TextBlock>
                                    </Grid>
                                </Button>

                                <Button Margin="0 0 0 20" Command="{Binding ShowReportViewCommand}">
                                    <Grid TextElement.FontSize="16" Width="231">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="DocumentSign" VerticalAlignment="Center" Width="20" Height="20"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0">Generate Report</TextBlock>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="20 20">
                            <Button Margin="0 0 0 0" Command="{Binding ExitApplicationCommand}">
                                <Grid TextElement.FontSize="16" Width="231">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="ExitToApp" VerticalAlignment="Center" Width="20" Height="20"/>
                                    <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0">Exit app</TextBlock>
                                </Grid>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!--Content-->
                <Border CornerRadius="0 0 10 0" Grid.Column="1" >
                    <ContentControl
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Stretch" 
                                       VerticalAlignment="Stretch" 
                                       UseLayoutRounding="True">
                        <materialDesign:TransitioningContent Content="{Binding CurrentView}" />
                    </ContentControl>
                </Border>

                    <Grid Grid.Column="1" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Width="500" Height="100" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="សូមរងចាំមួយភ្លេទសិន..." FontSize="32" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                        <ProgressBar
                            Background="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                            IsIndeterminate="True"
                            Width="400"
                            Height="6" 
                            Margin="0 10 0 0"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
    
</Window>
