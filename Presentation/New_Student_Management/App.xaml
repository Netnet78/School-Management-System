<Application x:Class="New_Student_Management.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:New_Student_Management"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:New_Student_Management.ViewModels"
             xmlns:views="clr-namespace:New_Student_Management.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary 
                Source="/School_Management.Presentation.Shared;component/Themes.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:StudentViewModel}">
                <views:StudentTableView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:InsertStudentViewModel}">
                <views:InsertStudentView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EditStudentViewModel}">
                <views:EditStudentView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportViewModel}">
                <views:ReportView />
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
