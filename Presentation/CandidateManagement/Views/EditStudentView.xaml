<UserControl x:Class="CandidateManagement.Views.EditStudentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:viewmodels="clr-namespace:CandidateManagement.ViewModels" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:EditStudentViewModel}"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <UserControl.Resources>
        <conv:IntEqualsToVisibilityConverter x:Key="IntEqualsToVisibilityConverter" />
        <conv:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:ValidPathToVisibilityConverter x:Key="ValidPathToVisibilityConverter" Reversed="False" />
        <conv:ValidPathToVisibilityConverter x:Key="ValidPathToVisibilityConverterReversed" Reversed="True"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="8" Padding="16" Margin="0 0 0 16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="AccountEdit" Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" Width="48" Height="48" Margin="0 0 16 0"/>
                <TextBlock Text="{Binding EditedStudent.Id, StringFormat='កែប្រែទិន្នន័យនៃ: DBS{0:000}', FallbackValue='កែប្រែទិន្នន័យរបស់: DBS000'}" 
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" 
                           FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form Content in a Card -->
        <materialDesign:Card Grid.Row="1" Padding="24" UniformCornerRadius="8" TextElement.FontSize="16" TextElement.FontFamily="{StaticResource NotoSansKhmer}">
            <Grid>
                <!-- Step 0: Personal -->
                <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=0}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ព័ត៌មានផ្ទាល់ខ្លួន" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="{Binding EditedStudent.LastName}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="គោត្តនាម" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.LatinLastName}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="គោត្តនាមជាអក្សរឡាតាំង" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.FirstName}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="នាម" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.LatinFirstName}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="នាមជាអក្សរឡាតាំង" Margin="0,8"/>
                                
                                <ComboBox SelectedValue="{Binding EditedStudent.Gender}" Style="{StaticResource MaterialDesignFloatingHintComboBox}" materialDesign:HintAssist.Hint="ភេទ" IsEditable="False" DisplayMemberPath="Description" SelectedValuePath="Value" ItemsSource="{Binding GenderOptions}" Margin="0,8"/>
                                
                                <DatePicker SelectedDate="{Binding EditedStudent.DateOfBirth, FallbackValue='12/12/2012', Converter={StaticResource DateOnlyToDateTimeConverter}}" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" materialDesign:HintAssist.Hint="កាលបរិច្ឆេទកំណើត" Margin="0,8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <ComboBox SelectedValue="{Binding EditedStudent.SkillId}" Style="{StaticResource MaterialDesignFloatingHintComboBox}" materialDesign:HintAssist.Hint="ជំនាញ" DisplayMemberPath="KhmerName" SelectedValuePath="Id" IsEditable="False" ItemsSource="{Binding SkillOptions}" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.Religion}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="សាសនា" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.SiblingsCount}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ចំនួនបងប្អូន" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.PhoneNumber}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="លេខទូរស័ព្ទ" Margin="0,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Step 1: Birth location -->
                <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=1}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ទីកន្លែងកំណើត" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="{Binding EditedStudent.BirthVillage}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ភូមិ" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.BirthCommune}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ឃុំ/សង្កាត់" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.BirthDistrict}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ស្រុក/ក្រុង" Margin="0,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBox Text="{Binding EditedStudent.BirthProvince}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ខេត្ត" Margin="0,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Step 2: Father / Mother info -->
                <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=2}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ឪពុក និង ម្ដាយ" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="{Binding EditedStudent.MotherName}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ឈ្មោះម្ដាយ" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.MotherOccupation}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="មុខរបរម្ដាយ" Margin="0,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBox Text="{Binding EditedStudent.FatherName}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ឈ្មោះឪពុក" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.FatherOccupation}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="មុខរបរឪពុក" Margin="0,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Step 3: Exam & Other -->
                <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=3}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ព័ត៌មានប្រឡង និង ផ្សេងៗ" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="{Binding EditedStudent.ExamCenter}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="មណ្ឌលប្រឡង" Margin="0,8"/>
                                <DatePicker SelectedDate="{Binding EditedStudent.ExamDate, Converter={StaticResource DateOnlyToDateTimeConverter}}" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" materialDesign:HintAssist.Hint="កាលបរិច្ឆេទប្រឡង" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.ExamTable}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="លេខតុ" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.ExamRoom}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="លេខបន្ទប់" Margin="0,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBox Text="{Binding EditedStudent.FromSchool}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="មកពីសាលារៀន" Margin="0,8"/>
                                <ComboBox ItemsSource="{Binding StayTypeOptions}" DisplayMemberPath="Description" SelectedValuePath="Value" SelectedValue="{Binding EditedStudent.StayType}" Style="{StaticResource MaterialDesignFloatingHintComboBox}" materialDesign:HintAssist.Hint="ការស្នាក់នៅ" IsEditable="False" Margin="0,8"/>
                                <TextBox Text="{Binding EditedStudent.OtherInfo}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="ផ្សេងៗ" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="80" Margin="0,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Step 4: Picture -->
                <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=4}" VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="ព័ត៌មានរូបភាព" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,24" HorizontalAlignment="Center"/>
                        
                        <materialDesign:Card Width="240" Height="300" Padding="8" UniformCornerRadius="8" Background="{DynamicResource MaterialDesign.Brush.Surface}">
                            <Grid>
                                <Image Stretch="UniformToFill"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding CurrentPhoto.FilePath, Converter={StaticResource ValidPathToVisibilityConverter}, FallbackValue=Collapsed}"
                                       Source="{Binding CurrentPhoto.FilePath, Converter={StaticResource PhotoPathToImageSourceConverter}}">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,224,284" RadiusX="8" RadiusY="8"/>
                                    </Image.Clip>
                                </Image>
                                
                                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                                        BorderThickness="2" CornerRadius="8"
                                        Visibility="{Binding CurrentPhoto.FilePath, Converter={StaticResource ValidPathToVisibilityConverterReversed}, FallbackValue='Visible'}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="AccountBoxOutline" Width="96" Height="96" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="គ្មានរូបភាព" FontSize="18" Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                        
                        <Button Margin="0 24 0 0" Command="{Binding UploadPhotoCommand}" Width="200" Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageEdit" Margin="0 0 8 0"/>
                                <TextBlock Text="បង្ហោះរូបភាពថ្មី" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </materialDesign:Card>

        <!-- Footer: navigation -->
        <Border Grid.Row="2" Background="{DynamicResource MaterialDesign.Brush.Surface}" CornerRadius="8" Padding="16" Margin="0 16 0 0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Margin="0,0,8,0" Command="{Binding BackCommand}" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Margin="0 0 8 0"/>
                            <TextBlock Text="ត្រលប់ក្រោយ" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0" Command="{Binding NextCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="120">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="បន្ទាប់" Margin="0 0 8 0"/>
                            <materialDesign:PackIcon Kind="ArrowRight" />
                        </StackPanel>  
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="0,0,8,0" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="Red" BorderBrush="Red">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cancel" Margin="0 0 8 0"/>
                            <TextBlock Text="បោះបង់" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Margin="0 0 8 0"/>
                            <TextBlock Text="រក្សាទុក" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
