<UserControl x:Class="CandidateManagement.Views.StudentTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:CandidateManagement.ViewModels"
             xmlns:conv="clr-namespace:SchoolManagement.Presentation.Shared.XAMLConverters;assembly=SchoolManagement.Presentation.Shared"
             d:DataContext="{d:DesignInstance Type=viewmodels:StudentViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="1050"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <!-- Safe fallback for designer when the global MaterialDesignDivider key is not available -->
    <UserControl.Resources>
        <conv:DataRowBrushConverter x:Key="DataRowBrushConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" CollapseWhenNull="True" />
        <conv:NullToBooleanConverter x:Key="NullToBooleanConverter" FalseOnNull="True" />
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" Collapse="True" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterReversed" IsReversed="True" Collapse="True" />
        <conv:ValidPathToVisibilityConverter x:Key="ValidPathToVisiblity" />
        <conv:ValidPathToVisibilityConverter x:Key="ValidPathToVisiblityReversed" Reversed="True"/>
        
        <Storyboard x:Key="LoadingRotate" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoadingIndicator" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(RotateTransform.Angle)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadingRotate}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="FilterDialog"
              Panel.ZIndex="1"
              Grid.Row="1"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Visibility="{Binding ShowFilterDialog, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}">
            <Border Background="White" 
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" 
                    BorderThickness="4"
                    Width="600"
                    Height="550"
                    CornerRadius="20"
                    Padding="40">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Filter" Width="24" Height="24"/>
                        <TextBlock Text="ការច្រោះយកទិន្នន័យសិស្ស" FontWeight="Bold" FontSize="24" Margin="10 0 0 0"/>
                    </StackPanel>
                    <Rectangle Margin="0 5" Height="5" Fill="{DynamicResource MaterialDesign.Brush.Primary}"/>

                    <StackPanel TextElement.FontSize="18">
                        <StackPanel Margin="0 15">
                            <TextBlock Text="ភេទសិស្ស៖" FontWeight="Bold"/>
                            <ComboBox SelectedValue="{Binding SelectedGender}"
                                      ItemsSource="{Binding GenderOptions}"
                                      DisplayMemberPath="KhmerName"
                                      SelectedValuePath="Value"/>
                        </StackPanel>
                        <StackPanel Margin="0 15">
                            <TextBlock Text="ថ្ងៃចុះឈ្មោះ៖" Margin="0 0 15 10" FontWeight="Bold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <DockPanel>
                                    <TextBlock VerticalAlignment="Center" Margin="0 0 10 0">ចាប់ពី</TextBlock>
                                    <DatePicker SelectedDate="{Binding FromDate}"/>
                                </DockPanel>
                                <Border Width="10" Grid.Column="1"/>
                                <DockPanel Grid.Column="2">
                                    <TextBlock VerticalAlignment="Center" Margin="0 0 10 0">ដល់ថ្ងៃ</TextBlock>
                                    <DatePicker SelectedDate="{Binding ToDate}"/>
                                </DockPanel>
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0 15">
                            <TextBlock Text="រៀបលំដាប់លំដោយតាម៖" FontWeight="Bold"/>
                            <ComboBox SelectedValue="{Binding SortBy}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="ID" Tag="Id"/>
                                <ComboBoxItem Content="ឈ្មោះពេញ" Tag="FullName"/>
                                <ComboBoxItem Content="ឈ្មោះពេញ (ឡាតាំង)" Tag="LatinFullName"/>
                                <ComboBoxItem Content="កាលបរិច្ឆេទបង្កើត" Tag="CreatedAt"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0 15">
                            <TextBlock Text="ប្រភេទនៃលំដាប់លំដោយ៖" FontWeight="Bold"/>
                            <ComboBox SelectedValue="{Binding OrderType}"
                                      ItemsSource="{Binding OrderTypeOptions}"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Margin="0 0 0 0" Grid.Column="0" Command="{Binding SetFiltersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Check" Margin="0 0 10 0" VerticalAlignment="Center"/>
                                <TextBlock>ចាប់ផ្ដើមច្រោះទិន្នន័យ</TextBlock>
                            </StackPanel>
                        </Button>
                        <Border Width="10" Grid.Column="1"/>
                        <Button Margin="0 0 0 0" Grid.Column="2" Background="Red" BorderBrush="Black" Command="{Binding ToggleFilterDialogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Remove" Margin="0 0 10 0" VerticalAlignment="Center"/>
                                <TextBlock>ចាកចេញ (Cancel)</TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!--Header / Title-->
        <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Grid.Row="0"  Height="60">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Table" VerticalAlignment="Center" Height="32" Width="32" />
                <TextBlock  Padding="10" Text="តារាងបញ្ជីសិស្សានុសិស្ស" FontSize="24" FontWeight="Bold" />
            </StackPanel>
        </Grid>

        <!--Table of Students-->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!--Color indicators & Commands-->
            <!--Commands section-->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="10 5">
                <StackPanel Orientation="Horizontal" Margin="0 0">
                    <TextBlock VerticalAlignment="Center" FontSize="14">
                        ពណ៌សម្រាប់សម្គាល់ស្ថានភាពព័ត៌មាន៖
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Border Height="25" Width="25" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="ព័ត៌មានពេញលេញ" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Height="25" Width="25" BorderBrush="Black" Background="Yellow" BorderThickness="1" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="ព័ត៌មានមិនទាន់ពេញលេញ" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Height="25" Width="25" BorderBrush="Black" Background="OrangeRed" BorderThickness="1" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="ខ្វះព័ត៌មានរូបភាព" />
                    </StackPanel>
                </StackPanel>

                <!--Commands section-->
                <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                    <!--Update data button-->
                    <Button Margin="0 0 20 0" Command="{Binding LoadStudentsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Height="16" Width="16" />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Margin="5 0 0 0" Text="ធ្វើបច្ចុប្បន្នភាពទិន្នន័យ" />
                        </StackPanel>
                    </Button>
                    <!--Edit data button-->
                    <Button Command="{Binding EditStudentCommand}" Margin="0 0 20 0"
                                        IsEnabled="{Binding SelectedStudent, Converter={StaticResource NullToBooleanConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Pencil" VerticalAlignment="Center" Height="16" Width="16" />
                            <TextBlock VerticalAlignment="Center"
                                                    FontSize="14"
                                                    Margin="5 0 0 0"
                                                    Text="{Binding SelectedStudent.FullName, StringFormat=កែប្រែទិន្នន័យ {0}, FallbackValue='កែប្រែទិន្នន័យ'}" />
                        </StackPanel>
                    </Button>

                    <!--Delete data button-->
                    <Button Command="{Binding DeleteStudentCommand}" Margin="0 0 20 0"
                                        IsEnabled="{Binding SelectedStudent, Converter={StaticResource NullToBooleanConverter}}"
                                        Background="Red"
                                        BorderBrush="Black">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Trash" VerticalAlignment="Center" Height="16" Width="16" />
                            <TextBlock VerticalAlignment="Center"
                                                    FontSize="14"
                                                    Margin="5 0 0 0"
                                                    Text="{Binding SelectedStudent.FullName, StringFormat=លុបទិន្នន័យ {0}, FallbackValue='លុបទិន្នន័យ'}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--Data View Manipulation section-->
                <ScrollViewer Margin="0 5 0 0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="0 10 0 5">
                        <StackPanel Orientation="Horizontal" Margin="0 0 20 0">
                            <ToggleButton IsChecked="{Binding ToggleLatinNames, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="10 0 0 0" FontSize="16" VerticalAlignment="Center">
                                បង្ហាញនាមជាអក្សរឡាតាំង
                            </TextBlock>
                        </StackPanel>

                        <Rectangle Fill="{DynamicResource MaterialDesign.Brush.Foreground}"
                                            Width="2"
                                            Margin="0 0 20 0" />

                        <StackPanel Orientation="Horizontal" Margin="0 0 20 0">
                            <TextBlock Margin="0 0 10 0" FontSize="16" VerticalAlignment="Center">
                                ស្ថានភាពព័ត៌មាន៖
                            </TextBlock>
                            <ComboBox Width="160" Height="32"
                                                    IsEditable="False"
                                                    SelectedValue="{Binding DataStateFilter, Mode=TwoWay, TargetNullValue=''}"
                                                    DisplayMemberPath="Description"
                                                    SelectedValuePath="Value"
                                                    ItemsSource="{Binding DataStateFilterItems}"
                                                    x:Name="DataFilters" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Margin="0 10">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ToggleFilterDialogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Filter" VerticalAlignment="Center"/>
                                <TextBlock Text="ច្រោះទិន្នន័យ" Margin="10 0 0 0"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="20 0 0 0" Background="Red" BorderBrush="Black" Command="{Binding ClearFiltersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilterRemove" VerticalAlignment="Center"/>
                                <TextBlock Text="លុបជម្រើសនៃការច្រោះ" Margin="10 0 0 0"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" Margin="20 0 0 0">
                            <TextBlock Margin="0 0 10 0" FontSize="16" VerticalAlignment="Center">
                                ស្វែងរក៖
                            </TextBlock>
                            <TextBox Width="160"
                                              Text="{Binding StudentSearch, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                            <materialDesign:PackIcon Kind="Search"
                                                                            Width="32" Height="32"
                                                                            Foreground="Gray" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Orientation="Horizontal" Margin="0 5 0 0" TextElement.FontSize="16">
                    <Button ToolTip="រំលងថយក្រោយ 5 ទំព័រ" CommandParameter="-5" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronDoubleLeft" />
                    </Button>
                    <Button Margin="10 0 0 0" ToolTip="រំលងថយក្រោយ 1 ទំព័រ" CommandParameter="-1" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronLeft" />
                    </Button>

                    <TextBlock Text="ទំព័រទី" Margin="10 0 0 0" VerticalAlignment="Center"/>
                    <TextBox Margin="10 0 0 0" Width="48" BorderThickness="2" FontSize="16" Text="{Binding CurrentPage, FallbackValue=1, Mode=TwoWay}" TextAlignment="Center" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="នៃ" Margin="10 0 0 0" VerticalAlignment="Center" FontSize="16"/>
                    <Border Margin="10 0 0 0" Width="48" BorderThickness="2" BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}">
                        <TextBlock FontSize="16" Text="{Binding MaximumPages, FallbackValue=12}" VerticalAlignment="Center" TextAlignment="Center" Margin="0 4 0 0"/>
                    </Border>

                    <Button Margin="10 0 0 0" ToolTip="រំលងទៅមុខ 1 ទំព័រ" CommandParameter="1" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronRight" />
                    </Button>
                    <Button Margin="10 0 0 0" ToolTip="រំលងទៅមុខ 5 ទំព័រ" CommandParameter="5" Command="{Binding ChangePageIndexCommand}">
                        <materialDesign:PackIcon Kind="ChevronDoubleRight" />
                    </Button>
                </StackPanel>
            </StackPanel>

            <!--Table-->
            <!--Khmer Name Table-->
            <Border Grid.Row="2" Grid.Column="0"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}"
                    BorderThickness="2" Margin="10"
                    Visibility="{Binding ToggleLatinNames, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                <DataGrid    x:Name="StudentKhmerDataGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding StudentsView}"
                                          SelectionMode="Single"
                                          SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                                          Visibility="{Binding DataLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <!-- Move all DataGrid-specific styles into DataGrid.Resources to avoid designer FindAncestor issues -->
                    <DataGrid.Resources>
                        <!-- Row style that uses the data state converter -->
                        <Style TargetType="DataGridRow" x:Key="StudentRowStyle">
                            <Setter Property="Height" Value="40" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource DataRowBrushConverter}">
                                        <Binding Path="PhotoKey" />
                                        <Binding Path="FirstName" />
                                        <Binding Path="LastName" />
                                        <Binding Path="Gender" />
                                        <Binding Path="Skill" />
                                        <Binding Path="PhoneNumber" />
                                        <Binding Path="BirthVillage" />
                                        <Binding Path="BirthCommune" />
                                        <Binding Path="BirthDistrict" />
                                        <Binding Path="BirthProvince" />
                                        <Binding Path="FatherName" />
                                        <Binding Path="MotherName" />
                                        <Binding Path="FatherOccupation" />
                                        <Binding Path="MotherOccupation" />
                                        <Binding Path="Religion" />
                                        <Binding Path="ExamCenter" />
                                        <Binding Path="ExamDate" />
                                        <Binding Path="ExamTable" />
                                        <Binding Path="ExamRoom" />
                                        <Binding Path="FromSchool" />
                                        <Binding Path="StayType" />
                                        <Binding Path="SiblingsCount" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridCell" x:Key="StudentGridCellStyle">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                        </Style>

                        <!--Data text inside the grid styles-->
                        <Style TargetType="TextBlock" x:Key="StudentTextBlock">
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>

                        <Binding x:Key="ToggleLatinBinding"
                             Path="ToggleLatinNames"
                             NotifyOnSourceUpdated="True"
                             NotifyOnTargetUpdated="True" />
                    </DataGrid.Resources>

                    <!-- Apply the row style (explicit key ensures designer/runtime picks it up from DataGrid.Resources) -->
                    <DataGrid.RowStyle>
                        <StaticResource ResourceKey="StudentRowStyle" />
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <StaticResource ResourceKey="StudentGridCellStyle" />
                    </DataGrid.CellStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="Padding" Value="5" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខសម្គាល់" Binding="{Binding Id, StringFormat=DBS{0:000}}" Width="120" />
                        <DataGridTextColumn x:Name="FullName"
                                                                    ElementStyle="{StaticResource StudentTextBlock}"
                                                                    Header="គោត្តនាម និងនាម"
                                                                    Binding="{Binding FullName}"
                                                                    Width="200" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ភេទ" Binding="{Binding Gender, Converter={StaticResource EnumToDescriptionConverter}}" Width="80" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="កាលបរិច្ឆេទ​កំណើត" Binding="{Binding DateOfBirth}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="អាយុ" Binding="{Binding Age, StringFormat=' {0} ឆ្នាំ'}" Width="80" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ជំនាញ" Binding="{Binding Skill.KhmerName}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="សាសនា" Binding="{Binding Religion}" Width="120" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មណ្ឌលរឡងប្ប្រឡង" Binding="{Binding ExamCenter}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="កាលបរិច្ឆេទប្រឡង" Binding="{Binding ExamDate}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខតុ" Binding="{Binding ExamTable}" Width="100" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខបន្ទប់" Binding="{Binding ExamRoom}" Width="100" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះសាលារៀន" Binding="{Binding FromSchool}" Width="220" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ភូមិកំណើត" Binding="{Binding BirthVillage}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឃុំកំណើត" Binding="{Binding BirthCommune}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ស្រុកកំណើត" Binding="{Binding BirthDistrict}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ខេត្តកំណើត" Binding="{Binding BirthProvince}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះឪពុក" Binding="{Binding FatherName}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មុខរបរឪពុក" Binding="{Binding FatherOccupation}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះម្ដាយ" Binding="{Binding MotherName}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មុខរបរម្ដាយ" Binding="{Binding MotherOccupation}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="បងប្អូន" Binding="{Binding SiblingsCount, StringFormat=' {0} នាក់'}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ការស្នាក់នៅ" Binding="{Binding StayType, Converter={StaticResource EnumToDescriptionConverter}}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខទូរស័ព្ទ" Binding="{Binding PhoneNumber}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ផ្សេងៗ" Binding="{Binding OtherInfo}" Width="150" />
                        <!-- Hidden helpers for converter / selection -->
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="PhotoKey" Binding="{Binding PhotoKey}" Width="0" Visibility="Hidden" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="FirstName" Binding="{Binding FirstName}" Width="0" Visibility="Hidden" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="LastName" Binding="{Binding LastName}" Width="0" Visibility="Hidden" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!--Latin Name Table-->
            <Border Grid.Row="2" Grid.Column="0"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}"
                    BorderThickness="2" Margin="10"
                    Visibility="{Binding ToggleLatinNames, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue='Hidden'}">
                <DataGrid    x:Name="StudentLatinDataGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding StudentsView}"
                                          SelectionMode="Single"
                                          SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                                          Visibility="{Binding DataLoading, Converter={StaticResource BooleanToVisibilityConverterReversed}}">
                    <!-- Move all DataGrid-specific styles into DataGrid.Resources to avoid designer FindAncestor issues -->
                    <DataGrid.Resources>
                        <!-- Row style that uses the data state converter -->
                        <Style TargetType="DataGridRow" x:Key="StudentRowStyle">
                            <Setter Property="Height" Value="40" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource DataRowBrushConverter}">
                                        <Binding Path="PhotoKey" />
                                        <Binding Path="FirstName" />
                                        <Binding Path="LastName" />
                                        <Binding Path="Gender" />
                                        <Binding Path="Skill" />
                                        <Binding Path="PhoneNumber" />
                                        <Binding Path="BirthVillage" />
                                        <Binding Path="BirthCommune" />
                                        <Binding Path="BirthDistrict" />
                                        <Binding Path="BirthProvince" />
                                        <Binding Path="FatherName" />
                                        <Binding Path="MotherName" />
                                        <Binding Path="FatherOccupation" />
                                        <Binding Path="MotherOccupation" />
                                        <Binding Path="Religion" />
                                        <Binding Path="ExamCenter" />
                                        <Binding Path="ExamDate" />
                                        <Binding Path="ExamTable" />
                                        <Binding Path="ExamRoom" />
                                        <Binding Path="FromSchool" />
                                        <Binding Path="StayType" />
                                        <Binding Path="SiblingsCount" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridCell" x:Key="StudentGridCellStyle">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                        </Style>

                        <!--Data text inside the grid styles-->
                        <Style TargetType="TextBlock" x:Key="StudentTextBlock">
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>

                        <Binding x:Key="ToggleLatinBinding"
                             Path="ToggleLatinNames"
                             NotifyOnSourceUpdated="True"
                             NotifyOnTargetUpdated="True" />
                    </DataGrid.Resources>

                    <!-- Apply the row style (explicit key ensures designer/runtime picks it up from DataGrid.Resources) -->
                    <DataGrid.RowStyle>
                        <StaticResource ResourceKey="StudentRowStyle" />
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <StaticResource ResourceKey="StudentGridCellStyle" />
                    </DataGrid.CellStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="Padding" Value="5" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខសម្គាល់" Binding="{Binding Id, StringFormat=DBS{0:000}}" Width="120" />
                        <DataGridTextColumn x:Name="LatinFullName"
                                                                    ElementStyle="{StaticResource StudentTextBlock}"
                                                                    Header="គោត្តនាម និងនាម"
                                                                    Binding="{Binding LatinFullName}"
                                                                    Width="200" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ភេទ" Binding="{Binding Gender, Converter={StaticResource EnumToDescriptionConverter}}" Width="80" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="កាលបរិច្ឆេទ​កំណើត" Binding="{Binding DateOfBirth}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="អាយុ" Binding="{Binding Age, StringFormat=' {0} ឆ្នាំ'}" Width="80" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ជំនាញ" Binding="{Binding Skill.KhmerName}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="សាសនា" Binding="{Binding Religion}" Width="120" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មណ្ឌលរឡងប្ប្រឡង" Binding="{Binding ExamCenter}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="កាលបរិច្ឆេទប្រឡង" Binding="{Binding ExamDate}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខតុ" Binding="{Binding ExamTable}" Width="100" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខបន្ទប់" Binding="{Binding ExamRoom}" Width="100" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះសាលារៀន" Binding="{Binding FromSchool}" Width="220" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ភូមិកំណើត" Binding="{Binding BirthVillage}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឃុំកំណើត" Binding="{Binding BirthCommune}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ស្រុកកំណើត" Binding="{Binding BirthDistrict}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ខេត្តកំណើត" Binding="{Binding BirthProvince}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះឪពុក" Binding="{Binding FatherName}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មុខរបរឪពុក" Binding="{Binding FatherOccupation}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះម្ដាយ" Binding="{Binding MotherName}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មុខរបរម្ដាយ" Binding="{Binding MotherOccupation}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="បងប្អូន" Binding="{Binding SiblingsCount, StringFormat=' {0} នាក់'}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ការស្នាក់នៅ" Binding="{Binding StayType, Converter={StaticResource EnumToDescriptionConverter}}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខទូរស័ព្ទ" Binding="{Binding OtherInfo}" Width="150" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ផ្សេងៗ" Binding="{Binding OtherInfo}" Width="150" />
                        <!-- Hidden helpers for converter / selection -->
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="PhotoKey" Binding="{Binding PhotoKey}" Width="0" Visibility="Hidden" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="FirstName" Binding="{Binding FirstName}" Width="0" Visibility="Hidden" />
                        <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="LastName" Binding="{Binding LastName}" Width="0" Visibility="Hidden" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!--Selected Student Information-->
            <Border Grid.RowSpan="2"
                            Grid.Column="1"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                            BorderThickness="2"
                            CornerRadius="10"
                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                            Margin="10"
                            Visibility="{Binding SelectedStudent, Converter={StaticResource NullToVisibilityConverter}}"
                            Width="275">
                <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!--Picture, Name and ID-->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Grid.Row="0">
                        <Border
                               Margin="0 10 0 0"
                               BorderThickness="4"
                               Width="128"
                               BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}">
                            <Grid>
                                <materialDesign:PackIcon Kind="Loading"
                                                         x:Name="LoadingIndicator"
                                                         Width="74" 
                                                         Height="74" 
                                                         HorizontalAlignment="Center" 
                                                         VerticalAlignment="Center" 
                                                         RenderTransformOrigin="0.5,0.5"
                                                         Visibility="{Binding IsLoadingPhoto, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" 
                                                         Panel.ZIndex="1">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>

                                <Viewbox Visibility="{Binding ValidPhotoPath, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                                         MinHeight="154">
                                    <Image Stretch="Uniform"
                                           SnapsToDevicePixels="True"
                                           UseLayoutRounding="True"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="{Binding SelectedStudentPhoto, Converter={StaticResource PhotoPathToImageSourceConverter}}" />
                                </Viewbox>

                                <Border Visibility="{Binding ValidPhotoPath, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Visible}"
                                        Height="154">
                                    <Grid>
                                        <materialDesign:PackIcon Kind="UserQuestion" 
                                                         Width="64" 
                                                         Height="64" 
                                                         HorizontalAlignment="Center" 
                                                         VerticalAlignment="Center" 
                                                         Visibility="{Binding IsLoadingPhoto, Converter={StaticResource BooleanToVisibilityConverterReversed}, FallbackValue=Visible}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <TextBlock HorizontalAlignment="Center"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Margin="0 10"
                                            Text="{Binding SelectedStudent.FullName, FallbackValue='ឈ្មោះ'}"
                                            Visibility="{Binding ToggleLatinNames, Converter={StaticResource BooleanToVisibilityConverterReversed}}" />
                        <TextBlock HorizontalAlignment="Center"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Margin="0 10"
                                            Text="{Binding SelectedStudent.LatinFullName, FallbackValue='LATIN NAME'}"
                                            Visibility="{Binding ToggleLatinNames, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue='Collapsed'}" />
                        <TextBlock HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="{Binding SelectedStudent.Id, FallbackValue='DBS000', StringFormat=DBS{0:000}}" />
                    </StackPanel>
                    <!--Full Information-->
                    <Border Padding="10" Grid.Row="1" TextElement.FontSize="16" BorderBrush="Transparent">
                        <ScrollViewer Margin="0 5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="ព័ត៌មានផ្ទាល់ខ្លួន" FontWeight="Bold" Margin="0,8,0,4" />
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ភេទ:" />
                                    <TextBlock Text="{Binding SelectedStudent.Gender, Converter={StaticResource EnumToDescriptionConverter}}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="ថ្ងៃខែឆ្នាំកំណើត:" />
                                    <TextBlock Text="{Binding SelectedStudent.DateOfBirth, StringFormat=' {0:dd}/{0:MM}/{0:yyyy}'}" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="អាយុ:" />
                                    <TextBlock Text="{Binding SelectedStudent.Age, StringFormat=' {0:00} ឆ្នាំ'}" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="ជំនាញ:" />
                                    <TextBlock Text="{Binding SelectedStudent.Skill.KhmerName}" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="សាសនា:" />
                                    <TextBlock Text="{Binding SelectedStudent.Religion}" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="ចំនួនបងប្អូន:" />
                                    <TextBlock Text="{Binding SelectedStudent.SiblingsCount, StringFormat=' {0:00} នាក់'}" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="លេខទូរស័ព្ទ:" />
                                    <TextBlock Text="{Binding SelectedStudent.PhoneNumber}" Margin="10 0 0 0" />
                                </StackPanel>

                                <TextBlock Text="ទីកន្លែងកំណើត" FontWeight="Bold" Margin="0,8,0,4" />
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ភូមិ:" />
                                    <TextBlock Text="{Binding SelectedStudent.BirthVillage}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ឃុំ:" />
                                    <TextBlock Text="{Binding SelectedStudent.BirthCommune}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ស្រុក:" />
                                    <TextBlock Text="{Binding SelectedStudent.BirthDistrict}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ខេត្ត:" />
                                    <TextBlock Text="{Binding SelectedStudent.BirthProvince}" Margin="10 0 0 0" />
                                </StackPanel>

                                <TextBlock Text="ឪពុក និង ម្តាយ" FontWeight="Bold" Margin="0,8,0,4" />
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ឈ្មោះឪពុក:" />
                                    <TextBlock Text="{Binding SelectedStudent.FatherName}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="មុខរបរឪពុក:" />
                                    <TextBlock Text="{Binding SelectedStudent.FatherOccupation}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ឈ្មោះម្ដាយ:" />
                                    <TextBlock Text="{Binding SelectedStudent.MotherName}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="មុខរបរម្ដាយ:" />
                                    <TextBlock Text="{Binding SelectedStudent.MotherOccupation}" Margin="10 0 0 0" />
                                </StackPanel>

                                <TextBlock Text="ព័ត៌មានប្រឡង" FontWeight="Bold" Margin="0,8,0,4" />
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="មណ្ឌលប្រឡង:" />
                                    <TextBlock Text="{Binding SelectedStudent.ExamCenter}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="កាលបរិច្ឆេទ:" />
                                    <TextBlock Text="{Binding SelectedStudent.ExamDate, StringFormat=' {0:dd}/{0:MM}/{0:yyyy}'}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="លេខតុ:" />
                                    <TextBlock Text="{Binding SelectedStudent.ExamTable}" Margin="10 0 0 0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="លេខបន្ទប់:" />
                                    <TextBlock Text="{Binding SelectedStudent.ExamRoom}" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="មកពីសាលារៀន:" />
                                    <TextBlock Text="{Binding SelectedStudent.FromSchool}" Margin="10 0 0 0" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="ការស្នាក់នៅ:" FontStyle="Italic" />
                                    <TextBlock Text="{Binding SelectedStudent.StayType, Converter={StaticResource EnumToDescriptionConverter}}" TextWrapping="Wrap" Margin="10 0 0 0" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="ផ្សេងៗ:" FontStyle="Italic" />
                                    <TextBlock Text="{Binding SelectedStudent.OtherInfo}" TextWrapping="Wrap" Margin="10 0 0 0" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
