<UserControl x:Class="Student_Management.Views.InsertStudentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Student_Management.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:Student_Management.Converters"
             mc:Ignorable="d" 
             xmlns:viewmodels="clr-namespace:Student_Management.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:InsertStudentViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource MaterialDesign.Brush.Background}">
    <UserControl.Resources>
        <conv:IntEqualsToVisibilityConverter x:Key="IntEqualsToVisibilityConverter" />
        <conv:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:ValidPathToVisibility x:Key="ValidPathToVisibility" Reversed="False"/>
        <conv:ValidPathToVisibility x:Key="ValidPathToVisibilityReversed" Reversed="True"/>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4,3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4,3"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Header / Title-->
        <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Grid.Row="0"  Height="60">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AccountStudent" VerticalAlignment="Center" Height="32" Width="32"/>
                <TextBlock  Padding="10" Text="ទម្រង់បញ្ចូល​សិស្សានុសិស្ស" FontSize="24" FontWeight="Bold" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Content: three step panels -->
            <Grid Grid.Row="0" Margin="0,12,0,12" TextElement.FontSize="16" TextElement.FontFamily="{StaticResource NotoSansKhmer}">
                <!-- Step 0: Personal -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=0}">
                    <TextBlock Text="Section: ព័ត៌មានផ្ទាល់ខ្លួន" FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Width="320">
                            <TextBlock Text="គោត្តនាម" />
                            <TextBox Text="{Binding Data.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="នាម" />
                            <TextBox Text="{Binding Data.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="ភេទ" />
                            <ComboBox SelectedValue="{Binding Data.Gender, Mode=TwoWay}" 
                                               IsEditable="False" 
                                               DisplayMemberPath="Description"
                                               SelectedValuePath="Value" 
                                               ItemsSource="{Binding GenderOptions}"/>

                            <TextBlock Text="ថ្ងៃខែឆ្នាំកំណើត" Margin="0 5 0 0"/>
                            <DatePicker Name="DateOfBirthPicker"
                                               SelectedDate="{Binding Data.DateOfBirth, Mode=TwoWay, FallbackValue='12/12/2012', Converter={StaticResource DateOnlyToDateTimeConverter}}" />
                        </StackPanel>

                        <StackPanel Width="320" Margin="20,0,0,0">
                            <TextBlock Text="ជំនាញ" />
                            <ComboBox  SelectedValue="{Binding Data.Skill, Mode=TwoWay}"
                                                DisplayMemberPath="Description"
                                                SelectedValuePath="Value"
                                                IsEditable="False"
                                                ItemsSource="{Binding SkillOptions}"/>
                            <TextBlock Text="សាសនា" />
                            <TextBox Text="{Binding Data.Religion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="ចំនួនបងប្អូន" />
                            <TextBox Text="{Binding Data.SiblingsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>

                <!-- Step 1: Birth location -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=1}">
                    <TextBlock Text="Section: ទីកន្លែងកំណើត" FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Width="320">
                            <TextBlock Text="ភូមិ" />
                            <TextBox Text="{Binding Data.BirthVillage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="ឃុំ/សង្កាត់" />
                            <TextBox Text="{Binding Data.BirthCommune, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="ស្រុក/ក្រុង" />
                            <TextBox Text="{Binding Data.BirthDistrict, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="320" Margin="20,0,0,0">
                            <TextBlock Text="ខេត្ត" />
                            <TextBox Text="{Binding Data.BirthProvince, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>

                <!-- Step 2: Father / Mother info -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=2}">
                    <TextBlock Text="Section: ឪពុក និង ម្ដាយ" FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Width="320">
                            <TextBlock Text="ឈ្មោះម្ដាយ" />
                            <TextBox Text="{Binding Data.MotherName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="មុខរបរ" />
                            <TextBox Text="{Binding Data.MotherOccupation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="320" Margin="20,0,0,0">
                            <TextBlock Text="ឈ្មោះឪពុក" />
                            <TextBox Text="{Binding Data.FatherName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="មុខរបរ" />
                            <TextBox Text="{Binding Data.FatherOccupation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>

                <!-- Step 3: Exam & Other -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=3}">
                    <TextBlock Text="Section: ព័ត៌មានប្រឡង និង ផ្សេងៗ" FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <StackPanel Width="320">
                            <TextBlock Text="មណ្ឌល" />
                            <TextBox Text="{Binding Data.ExamCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="កាលបរិច្ឆេទ" />
                            <TextBox Text="{Binding Data.ExamDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="លេខតុ" />
                            <TextBox Text="{Binding Data.ExamTable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="លេខបន្ទប់" />
                            <TextBox Text="{Binding Data.ExamRoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Width="320" Margin="20,0,0,0">
                            <TextBlock Text="មកពីសាលារៀន" />
                            <TextBox Text="{Binding Data.FromSchool, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="ការស្នាក់នៅ" />
                            <ComboBox  ItemsSource="{Binding StayTypeOptions}"
                                                DisplayMemberPath="Description"
                                                SelectedValuePath="Value"
                                                SelectedValue="{Binding Data.StayType, Mode=TwoWay}" 
                                                IsEditable="False"/>
                            <TextBlock Text="ផ្សេងៗ" />
                            <TextBox Text="{Binding Data.OtherInfo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="100"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>

                <!-- Step 4: Picture -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource IntEqualsToVisibilityConverter}, ConverterParameter=4}">
                    <TextBlock Text="Section: ព័ត៌មានរូបភាព" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel>
                        <Image Stretch="Uniform"
                               Width="200" Height="200"
                               Margin="0 0 0 20"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="{Binding CurrentPhotoPath, Converter={StaticResource ValidPathToVisibility}}"
                               Source="{Binding CurrentPhotoPath, Converter={StaticResource PhotoPathToImageSourceConverter}}"/>
                        <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                                    BorderThickness="2"
                                    Width="160" Height="200"
                                    Visibility="{Binding CurrentPhotoPath, Converter={StaticResource ValidPathToVisibilityReversed}, FallbackValue='Collapsed'}">
                            <TextBlock HorizontalAlignment="Center" 
                                            VerticalAlignment="Center" 
                                            FontSize="64" 
                                            Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                            Text="?"/>
                        </Border>
                        <Button Margin="0 10" Command="{Binding UploadPhotoCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Image" Margin="0 0 5 0"/>
                                <TextBlock>បង្ហោះរូបភាព</TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Footer: navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,10">
                <Button Margin="4" Command="{Binding BackCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowBack" />
                        <TextBlock Text="Back" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Margin="4" Command="{Binding NextCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Next" Margin="0,0,4,0"/>
                        <materialDesign:PackIcon Kind="ArrowForward" />
                    </StackPanel>
                </Button>
                <Button Margin="4" Command="{Binding AddStudentCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AddBold" />
                        <TextBlock Text="Add Student" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
