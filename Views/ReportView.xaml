<UserControl x:Class="New_Student_Management.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:New_Student_Management.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:New_Student_Management.Converters"
             xmlns:viewmodels="clr-namespace:New_Student_Management.ViewModels"
             xmlns:components="clr-namespace:New_Student_Management.Components"
             d:DataContext="{d:DesignInstance Type=viewmodels:ReportViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <UserControl.Resources>
        <conv:StudentRowBrushConverter x:Key="StudentRowBrushConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" CollapseWhenNull="True"/>
        <conv:NullToBooleanConverter x:Key="NullToBooleanConverter" FalseOnNull="True"/>
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Header / Title-->
        <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Grid.Row="0"  Height="60">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ReportArc" VerticalAlignment="Center" Height="32" Width="32"/>
                <TextBlock  Padding="10" Text="របាយការណ៍ទិន្នន័យ" FontSize="24" FontWeight="Bold" />
            </StackPanel>
        </Grid>
        
        <!--Content-->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--Data Grid Columns-->
            <Grid Grid.Row="0" Grid.Column="0" Margin="10" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0 5" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="TableAccount" Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                    តារាងទិន្នន័យ​សិស្សានុសិស្សដែលបានចុះឈ្មោះ
                    </TextBlock>
                </StackPanel>
                
                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}" 
                            BorderThickness="2"
                            Grid.Row="1">
                    <TabControl Margin="0 0 0 0"
                                       ItemsSource="{Binding StudentTabs}"
                                       SelectedIndex="{Binding CurrentTabIndex, FallbackValue=0, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <!--Header Template-->
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Header}" FontSize="16"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <!--Content Template-->
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <components:StudentDataGrid
                                       ItemsSource="{Binding Data}"
                                       SelectedItem="{Binding DataContext.SelectedStudent,
                                       RelativeSource={RelativeSource AncestorType=TabControl}}" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Border>
            </Grid>
            
            <!--Summary Data Section-->
            <Grid Grid.Row="1" Margin="10 0 0 10" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" TextElement.FontSize="16">
                    <TextBlock Text="{Binding CurrentTabHeader, StringFormat=' ចំនួនសិស្ស {0} ', FallbackValue='ចំនួនសិស្ស គ្រប់ជំនាញ '}"/>
                    <TextBlock Text="{Binding CurrentTabStudentCount, StringFormat=' សរុបមាន {0} នាក់ ', FallbackValue=សរុបមាន ២៨ នាក់}"/>
                    <TextBlock Text="{Binding CurrentTabFemaleStudentCount, StringFormat=' នៅក្នុងនោះមានស្រី {0} នាក់', FallbackValue=នៅក្នុងនោះមានស្រី ១៧ នាក់}"/>
                </StackPanel>
            </Grid>

            <!--Buttons Section-->
            <Grid Grid.Row="2" Margin="10 0" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <!--Generate Candidate Report Button-->
                    <Button Height="40" 
                            VerticalAlignment="Top"
                            Command="{Binding GenerateCandidateReportCommand}"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 15">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TextUser"/>
                            <TextBlock Text="Generate Candidate Report" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!--Generate Department Report Button-->
                    <Button Height="40" 
                            VerticalAlignment="Top"
                            Command="{Binding GenerateDepartmentReportCommand}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Building"/>
                            <TextBlock Text="Generate Department Report" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>


                <StackPanel Grid.Column="1">
                    <WrapPanel Height="40" HorizontalAlignment="Right" Margin="0 0 0 10">
                        <TextBlock Text="កាលបរិច្ឆេទរបាយការណ៍: " 
                                            FontSize="16"
                                           VerticalAlignment="Center" 
                                           Margin="0,0,15,0"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                    
                        <!--Report Date Picker-->
                        <DatePicker Width="200"
                                            Height="40" 
                                            VerticalAlignment="Center"
                                            SelectedDate="{Binding ReportDate}"
                                            x:Name="ReportDate"
                                            VerticalContentAlignment="Center"
                                            FontSize="16"/>
                    </WrapPanel>
                    <WrapPanel Height="40" HorizontalAlignment="Right" Margin="0 0 0 10">
                        <TextBlock Text="ឆ្នាំសិក្សា: " 
                                            FontSize="16"
                                           VerticalAlignment="Center" 
                                           Margin="0,0,15,0"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>

                        <!--Report Date Picker-->
                        <TextBox Width="200"
                                            Height="40" 
                                            VerticalAlignment="Center"
                                            Text="{Binding StudyYear, FallbackValue='2025-2026'}"
                                            FontSize="16"
                                            x:Name="StudyYearInput"
                                            VerticalContentAlignment="Center"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
