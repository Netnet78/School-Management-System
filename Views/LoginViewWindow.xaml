<Window x:Class="New_Student_Management.Views.LoginViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:New_Student_Management.Views"
        xmlns:helpers="clr-namespace:New_Student_Management.Helpers" 
        xmlns:viewmodels="clr-namespace:New_Student_Management.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Login" Height="600" Width="850"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0" Margin="0 0 30 0" Source="/Sources/Images/Computer_Students.jpg"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Student Management - Login"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"
                       Grid.Row="0"/>

            <!-- Username -->
            <StackPanel Grid.Row="1" Margin="0 10 0 0" Orientation="Horizontal" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Username:" TextAlignment="Left" VerticalAlignment="Center"/>
                <TextBox Width="250"
                         Margin="10 0 0 0"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', FallbackValue='', Mode=TwoWay}"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Grid.Row="2" Margin="0 10 0 0" Orientation="Horizontal" Height="25" HorizontalAlignment="Center">
                <TextBlock Text="Password:" VerticalAlignment="Center"/>
                <PasswordBox Width="250"
                             Margin="10 0 0 0"
                             helpers:PasswordHelper.BindPassword="True"
                             helpers:PasswordHelper.Password="{Binding Password, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Login Button -->
            <Button Grid.Row="3"
                    Content="Login"
                    Height="35"
                    Width="100"
                    HorizontalAlignment="Center"
                    Margin="0 20 0 0"
                    Name="LoginButton"
                    Command="{Binding LoginCommand}"/>

        </Grid>
    </Grid>
</Window>
