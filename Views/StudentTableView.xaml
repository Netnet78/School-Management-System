<UserControl x:Class="Student_Management.Views.StudentTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Student_Management.Views" 
             xmlns:viewmodels="clr-namespace:Student_Management.ViewModels" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:Student_Management.Converters"
             xmlns:helpers="clr-namespace:Student_Management.Helpers"
             d:DataContext="{d:DesignInstance Type=viewmodels:StudentViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="1050"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <!-- Safe fallback for designer when the global MaterialDesignDivider key is not available -->
    <UserControl.Resources>
        <conv:StudentRowBrushConverter x:Key="StudentRowBrushConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" CollapseWhenNull="True"/>
        <conv:NullToBooleanConverter x:Key="NullToBooleanConverter" FalseOnNull="True"/>
        <conv:PhotoPathToImageSourceConverter x:Key="PhotoPathToImageSourceConverter" />
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Header / Title-->
        <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Grid.Row="0"  Height="60">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Table" VerticalAlignment="Center" Height="32" Width="32"/>
                <TextBlock  Padding="10" Text="តារាងបញ្ជីសិស្សានុសិស្ស" FontSize="24" FontWeight="Bold" />
            </StackPanel>
        </Grid>

        <!--Table of Students-->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            
            <!--Color indicators & Commands-->
            <!--Commands section-->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="10 5">
                <StackPanel Orientation="Horizontal" Margin="0 0">
                    <TextBlock VerticalAlignment="Center" FontSize="14">
                        ពណ៌សម្រាប់សម្គាល់ស្ថានភាពព័ត៌មាន៖
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Border Height="25" Width="25" BorderBrush="Black" BorderThickness="1" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="ព័ត៌មានពេញលេញ" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Height="25" Width="25" BorderBrush="Black" Background="Yellow" BorderThickness="1" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="ព័ត៌មានមិនទាន់ពេញលេញ" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Height="25" Width="25" BorderBrush="Black" Background="OrangeRed" BorderThickness="1" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="ខ្វះព័ត៌មានរូបភាព" />
                    </StackPanel>
                </StackPanel>
                
                <!--Commands section-->
                <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                    <!--Update data button-->
                    <StackPanel Orientation="Horizontal" Margin="0 0 20 0">
                        <Button Command="{Binding LoadStudentsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Height="16" Width="16" />
                                <TextBlock VerticalAlignment="Center" FontSize="14" Margin="5 0 0 0" Text="ធ្វើបច្ចុប្បន្នភាពទិន្នន័យ"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!--Edit data button-->
                    <StackPanel Orientation="Horizontal" Margin="0 0 20 0">
                        <Button Command="{Binding EditStudentCommand}" 
                                        IsEnabled="{Binding SelectedStudent, Converter={StaticResource NullToBooleanConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" VerticalAlignment="Center" Height="16" Width="16" />
                                <TextBlock VerticalAlignment="Center" 
                                                    FontSize="14" 
                                                    Margin="5 0 0 0" 
                                                    Text="{Binding SelectedStudent.FullName, StringFormat=កែប្រែទិន្នន័យ {0}, FallbackValue='កែប្រែទិន្នន័យ'}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!--Table-->
            <Border Grid.Row="2" Grid.Column="0" BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground}" BorderThickness="2" Margin="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <DataGrid
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Students}"
                  SelectionMode="Single"
                  SelectedItem="{Binding SelectedStudent, Mode=TwoWay}">
                        <!-- Move all DataGrid-specific styles into DataGrid.Resources to avoid designer FindAncestor issues -->
                        <DataGrid.Resources>
                            <!-- Row style that uses the converter -->
                            <Style TargetType="DataGridRow" x:Key="StudentRowStyle">
                                <Setter Property="Height" Value="40" />
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource StudentRowBrushConverter}">
                                            <Binding Path="PhotoPath" />
                                            <Binding Path="FirstName" />
                                            <Binding Path="LastName" />
                                            <Binding Path="Gender" />
                                            <Binding Path="Skill" />
                                            <Binding Path="BirthVillage" />
                                            <Binding Path="BirthCommune" />
                                            <Binding Path="BirthDistrict" />
                                            <Binding Path="BirthProvince" />
                                            <Binding Path="FatherName" />
                                            <Binding Path="MotherName" />
                                            <Binding Path="FatherOccupation" />
                                            <Binding Path="MotherOccupation" />
                                            <Binding Path="Religion" />
                                            <Binding Path="ExamCenter" />
                                            <Binding Path="ExamDate" />
                                            <Binding Path="ExamTable" />
                                            <Binding Path="ExamRoom" />
                                            <Binding Path="FromSchool" />
                                            <Binding Path="StayType" />
                                            <Binding Path="SiblingsCount" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ToolTip" Value="{Binding PhotoPath, StringFormat=Photo: {0}}" />
                            </Style>

                            <!-- Cell style placed here so RelativeSource/Ancestor (if later used) resolves correctly in designer -->
                            <Style TargetType="DataGridCell" x:Key="StudentGridCellStyle">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                            </Style>

                            <!--Data inside the grid styles-->
                            <Style TargetType="TextBlock" x:Key="StudentTextBlock">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <!-- Apply the row style (explicit key ensures designer/runtime picks it up from DataGrid.Resources) -->
                        <DataGrid.RowStyle>
                            <StaticResource ResourceKey="StudentRowStyle" />
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <StaticResource ResourceKey="StudentGridCellStyle" />
                        </DataGrid.CellStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontFamily" Value="{StaticResource NotoSansKhmer}" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខសម្គាល់" Binding="{Binding Id, StringFormat=DBS{0:000}}" Width="120" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="គោត្តនាម និងនាម" Binding="{Binding FullName}" Width="200" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ភេទ" Binding="{Binding Gender, Converter={StaticResource EnumToDescriptionConverter}}" Width="80" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ថ្ងៃខែឆ្នាំកំណើត" Binding="{Binding DateOfBirth}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="អាយុ" Binding="{Binding Age, StringFormat=' {0} ឆ្នាំ'}" Width="80" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ជំនាញ" Binding="{Binding Skill, Converter={StaticResource EnumToDescriptionConverter}}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="សាសនា" Binding="{Binding Religion}" Width="120" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="មណ្ឌលប្រឡង" Binding="{Binding ExamCenter}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="កាលបរិច្ឆេទប្រឡង" Binding="{Binding ExamDate}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខតុ" Binding="{Binding ExamTable}" Width="100" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="លេខបន្ទប់" Binding="{Binding ExamRoom}" Width="100" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះសាលារៀន" Binding="{Binding FromSchool}" Width="220" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ភូមិកំណើត" Binding="{Binding BirthVillage}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឃុំកំណើត" Binding="{Binding BirthCommune}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ស្រុកកំណើត" Binding="{Binding BirthDistrict}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ខេត្តកំណើត" Binding="{Binding BirthProvince}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះឪពុក" Binding="{Binding FatherName}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ឈ្មោះម្ដាយ" Binding="{Binding MotherName}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="បងប្អូន" Binding="{Binding SiblingsCount, StringFormat=' {0} នាក់'}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ការស្នាក់នៅ" Binding="{Binding StayType, Converter={StaticResource EnumToDescriptionConverter}}" Width="150" />
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="ផ្សេងៗ" Binding="{Binding OtherInfo}" Width="150" />
                            <!-- Hidden helpers for converter / selection -->
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="PhotoPath" Binding="{Binding PhotoPath}" Width="0" Visibility="Hidden"/>
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="FirstName" Binding="{Binding FirstName}" Width="0" Visibility="Hidden"/>
                            <DataGridTextColumn ElementStyle="{StaticResource StudentTextBlock}" Header="LastName" Binding="{Binding LastName}" Width="0" Visibility="Hidden"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>

            </Border>
            
            <Border Grid.RowSpan="2"
                            Grid.Column="1"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                            BorderThickness="2"
                            CornerRadius="10"
                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                            Margin="10"
                            Visibility="{Binding SelectedStudent, Converter={StaticResource NullToVisibilityConverter}}"
                            Width="275">
                <Grid TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!--Picture, Name and ID-->
                    <StackPanel Orientation="Vertical" Grid.Row="0" HorizontalAlignment="Center">
                        <Image Stretch="Uniform"
                               Width="128" Height="128"
                               Margin="0 10 0 0"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding SelectedStudent.PhotoPath, Converter={StaticResource PhotoPathToImageSourceConverter}}"/>
                        <TextBlock HorizontalAlignment="Center"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Margin="0 10"
                                            Text="{Binding SelectedStudent.FullName, FallbackValue='ឈ្មោះ'}"/>
                        <TextBlock HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="{Binding SelectedStudent.Id, FallbackValue='DBS000', StringFormat=DBS{0:000}}"/>
                    </StackPanel>
                    <!--Full Information-->
                    <Border Padding="10" Grid.Row="1" TextElement.FontSize="16" BorderBrush="Transparent">
                        <ScrollViewer Margin="0 5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="ព័ត៌មានផ្ទាល់ខ្លួន" FontWeight="Bold" Margin="0,8,0,4"/>
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ភេទ:" />
                                    <TextBlock Text="{Binding SelectedStudent.Gender, Converter={StaticResource EnumToDescriptionConverter}}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="ថ្ងៃខែឆ្នាំកំណើត:" />
                                    <TextBlock Text="{Binding SelectedStudent.DateOfBirth, StringFormat=' {0:dd}/{0:MM}/{0:yyyy}'}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="អាយុ:" />
                                    <TextBlock Text="{Binding SelectedStudent.Age, StringFormat=' {0:00} ឆ្នាំ'}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="ជំនាញ:" />
                                    <TextBlock Text="{Binding SelectedStudent.Skill, Converter={StaticResource EnumToDescriptionConverter}}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="សាសនា:" />
                                    <TextBlock Text="{Binding SelectedStudent.Religion}" Margin="10 0 0 0"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="ចំនួនបងប្អូន:" />
                                    <TextBlock Text="{Binding SelectedStudent.SiblingsCount, StringFormat=' {0:00} នាក់'}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <TextBlock Text="ទីកន្លែងកំណើត" FontWeight="Bold" Margin="0,8,0,4"/>
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ភូមិ:"/>
                                    <TextBlock Text="{Binding SelectedStudent.BirthVillage}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ឃុំ:"/>
                                    <TextBlock Text="{Binding SelectedStudent.BirthCommune}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ស្រុក:"/>
                                    <TextBlock Text="{Binding SelectedStudent.BirthDistrict}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ខេត្ត:"/>
                                    <TextBlock Text="{Binding SelectedStudent.BirthProvince}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <TextBlock Text="ឪពុក និង ម្តាយ" FontWeight="Bold" Margin="0,8,0,4"/>
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ឈ្មោះឪពុក:"/>
                                    <TextBlock Text="{Binding SelectedStudent.FatherName}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ការងារឪពុក:"/>
                                    <TextBlock Text="{Binding SelectedStudent.FatherOccupation}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ឈ្មោះម្ដាយ:"/>
                                    <TextBlock Text="{Binding SelectedStudent.MotherName}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ការងារម្ដាយ:"/>
                                    <TextBlock Text="{Binding SelectedStudent.MotherOccupation}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <TextBlock Text="ព័ត៌មានប្រឡង" FontWeight="Bold" Margin="0,8,0,4"/>
                                <Rectangle Fill="White" Height="2" Width="220" HorizontalAlignment="Left" Margin="0 0 0 3"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="មណ្ឌល:"/>
                                    <TextBlock Text="{Binding SelectedStudent.ExamCenter}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="កាលបរិច្ឆេទ:"/>
                                    <TextBlock Text="{Binding SelectedStudent.ExamDate}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="លេខតុ:"/>
                                    <TextBlock Text="{Binding SelectedStudent.ExamTable}" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="លេខបន្ទប់:"/>
                                    <TextBlock Text="{Binding SelectedStudent.ExamRoom}" Margin="10 0 0 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="មកពីសាលារៀន:"/>
                                    <TextBlock Text="{Binding SelectedStudent.FromSchool}" Margin="10 0 0 0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="ការស្នាក់នៅ:" FontStyle="Italic"/>
                                    <TextBlock Text="{Binding SelectedStudent.StayType, Converter={StaticResource EnumToDescriptionConverter}}" TextWrapping="Wrap" Margin="10 0 0 0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="ផ្សេងៗ:" FontStyle="Italic"/>
                                    <TextBlock Text="{Binding SelectedStudent.OtherInfo}" TextWrapping="Wrap" Margin="10 0 0 0"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
